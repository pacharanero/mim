									<title>Care Plan Summary</title>
									<text>
										<list listType="ordered">
											<item>Medication management</item>
											<item>Accommodation difficulties</item>
											<item>Lack of structure to day / meaningful occupation</item>
											<item>Financial difficulties</item>
											<item>Treatment and monitoring of bipolar disorder</item>
											<item>Management of drug and alcohol misuse</item>
										</list>
									</text>
								</section>
							</component>
							<component contextConductionInd="true" typeCode="COMP">
								<templateId extension="COCD_TP146061UK01#component1" root="2.16.840.1.113883.2.1.3.2.4.18.2"/>
								<section classCode="DOCSECT" moodCode="EVN">
									<templateId extension="COCD_TP146061UK01#section2" root="2.16.840.1.113883.2.1.3.2.4.18.2"/>
									<id root="B48AC27D-9151-4939-8CDF-6AA01C05FBD5"/>
									<title>Care Plan Component: Medication Management</title>
									<text>
										<content ID="c1">Tony needs to take medication regularly to treat his mental illness.</content>
										<br/>
										<br/>Aims and Objectives:
										<list listType="ordered">
											<item>
												<content ID="c2">Tony to take medication regularly and safely.</content>
											</item>
											<item>
												<content ID="c3">Tony to be prescribed appropriate amounts of medication that successfully treat his illness and keep side effects to a minimum.</content>
											</item>
										</list>Interventions &amp; Actions:
										<list listType="ordered">
											<item>
												<content ID="c4">Education regarding need to take medication regularly. /Information about medication used and how to take and store it safely.</content>
											</item>
											<item>
												<content ID="c5">Regular monitoring of efficacy and side effects.</content>
											</item>
											<item>
												<content ID="c6">Regular blood tests for Clozapine prescriptions - blood results sent to Clozapine monitoring service.</content>
											</item>
											<item>
												<content ID="c7">Blood tests for lithium levels.</content>
											</item>
											<item>
												<content ID="c8">Prescriptions for clozapine to be issued by CMHT medical staff following clearance from clozapine monitoring service.</content>
											</item>
											<item>
												<content ID="c9">All other prescriptions to be issued by GP.</content>
											</item>
											<item>
												<content ID="c10">Liaison with community pharmacist to ensure their understanding of clozapine prescription process and regular supply of medication.</content>
											</item>
											<item>
												<content ID="c11">Regular monitoring of weight, blood pressure and blood sugar levels.</content>
											</item>
											<item>
												<content ID="c12">Education regarding need to maintain a healthy lifestyle, including exercise regime. GP to be advised of responsibility.</content>
											</item>
										</list>Frequency of Contact:
										<list listType="ordered">
											<item>
												<content ID="c13">Weekly visits from CMHN.</content>
											</item>
											<item>
												<content ID="c14">6 weekly outpatient appointments with Consultant Psychiatrist.</content>
											</item>
											<item>
												<content ID="c15">Attendance at Clozapine clinic for blood tests - variable frequency depending on results.</content>
											</item>
											<item>
												<content ID="c16">Fortnightly attendances at GP surgery to see practice nurse.</content>
											</item>
											<item>
												<content ID="c17">Weekly prescriptions from GP to be collected by Tony from local pharmacy.</content>
											</item>
										</list>
