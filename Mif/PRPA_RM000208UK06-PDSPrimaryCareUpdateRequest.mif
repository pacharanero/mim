            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The NHAIS or SDS User Id in the case of a GP Practice.</p>
                            <p>This identifier will be represented in the following way:</p>
                            <p>If a NHAIS User ID: </p>
                            <ul>
                                <li>The root attribute will contain an OID with the value " 2.16.840.1.113883.2.1.3.2.4.5"; </li>
                                <li>The extension attribute will contain the NHAIS User ID.</li>
                            </ul>
                            <p>If an SDS User ID:</p>
                            <ul>
                                <li>The root attribute will contain an OID with the value " 1.2.826.0.1285.0.2.0.65"; </li>
                                <li>The extension attribute will contain the SDS User ID.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
