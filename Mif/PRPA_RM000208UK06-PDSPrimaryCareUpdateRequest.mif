                    <text>
                        <p>
                            <b>States information pertinent to the root act. In this case it is dispensing authorisation reason information.</b>
                        </p>
                        <p>
                            <b>This must be used in conjunction with the <i>updateMode</i> attribute of the <i>CareProviderPaymentInfo</i> class in the following way:</b>
                        </p>
                        <ul>
                            <li>
                                <b>This link may be present where the <i>updateMode  </i>is set to 'added' or 'altered'</b>
                            </li>
                            <li>
                                <b>This link must not be present where the <i>updateMode</i> is set to 'removed'.</b>
                            </li>
                        </ul>Note: Where the updateMode is set to "added" or "altered", at least one of the subject and pertinentInformation links and associated classes must be present (i.e. where Care Provider Payment data is being added or altered, at least one of Dispensing Authorisation Reason and Residential Institution code must be provided).</text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PERT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates pertinent information.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PERT"/>
            </attribute>
