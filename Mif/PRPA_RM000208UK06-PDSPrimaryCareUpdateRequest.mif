    <ownedClass>
        <class isAbstract="false" name="PCRemovalRegistrationEvent">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.371" shapeTemplate="Act">
                    <position x="4.29996" y="5.89"/>
                    <size height="1.04778" width="3.5"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>Information about a patient being removed (or intending to be removed) from a Primary Care Providers list.</b>
                        </p>
                        <p>
                            <b>Additionally, in order to control the update semantics, the following will also be present: </b>
                        </p>
                        <ul>
                            <li>
                                <b>An <i>updateMode</i> attribute to indicate whether the item should be "added", "altered", or "removed" (mandatory).</b>
                            </li>
                        </ul>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="REG"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates this is a registration.<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="REG"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates this is an event.<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="04" fixedValue="04"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates the type of registration. </p>
                            <p> The Coded with Code System datatype flavour is used to carry this information as follows: </p>
                            <ul>
                                <li>The <i>code </i>attribute will contain the value from the list of codes in the <u>DemographicRegistrationType</u> vocabulary </li>
                            </ul>
                            <ul>
                                <li>The <i>codeSystem </i>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.165" </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicRegistrationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The time period in which this information is valid as a range, supplied in the <i>low </i>and <i>high </i>attributes of the IVL_TS.</p>
                            <p>The dates are full dates without time.</p>
                            <p>This attribute shall be used in conjunction with the <i>updateMode</i> attribute of <i>PCRemovalRegistrationEvent</i> in the following way:</p>
                            <ul>
                                <li>If the <i>updateMode</i> is set to "added" or "altered", and the source of the update is NHAIS, then this attribute shall be present.</li>
                                <li>If the <i>updateMode</i> is set to "added" or "altered", and the source of the update is Primary Care, this attribute shall not be present</li>
                                <li>If the <i>updateMode</i> is set to "removed", the <i>low</i> sub-element shall not be present, and the <i>high</i> sub-element may optionally be present.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="availabilityTime" sortKey="12">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The data on which the removal was requested by the remover.</p>
                            <p>Using Date Only flavour - YYYYMMDD.</p>
                            <p>This must be present when a Reason For Removal is being added or altered by a primary care provider, but will not be present where it is being removed, or added or altered by NHAIS. </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="availabilityTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="reasonCode" sortKey="20">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>The reason for removal. The Coded with Code System datatype flavour is used to carry this information as follows: </p>
                                <ul>
                                    <li>The <em>code </em>attribute will contain a value from the list of codes in the <u>NHAISRemovalReasonCode </u>vocabulary </li>
                                </ul>
                                <ul>
                                    <li>The <em>codeSystem </em>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.168" </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="reasonCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="NHAISRemovalReasonCode"/>
            </attribute>
        </class>
    </ownedClass>
