    <ownedClass>
        <class isAbstract="false" name="DonorPreferredAddress">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.299" shapeTemplate="Act">
                    <position x="5.49383" y="13.42277"/>
                    <size height="0.78112" width="3.01227"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>The patients preferred address for blood donation purposes. This is not persisted on PDS but passed on to the Blood Donation Register.</b>
                        </p>
                        <p>
                            <b>A blood donor preferred address may only be supplied when other blood donor preference information is being added or altered.<br/>
                            </b>
                        </p>
                        <p/>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an observation. </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an event.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="40" fixedValue="40"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates the type of observation. </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i> attribute will contain the fixed value shown. </li>
                                <li>The <i>codeSystem</i> attribute will contain the OID for the vocabulary. </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <p>
                                    <font face="Times New Roman" size="3">The preferred address of the patient for  blood donation purposes.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The particular flavour of the address datatype used here is Address streetAddressLine Typed (format 2 in the datatypes description), plus:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">Optional Postcode</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Optional Address Key</font>
                                    </li>
                                </ul>
                                <p>
                                    <font face="Times New Roman" size="3">This means that the address will contain  the following components:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">Between one and four  <i>streetAddressLine</i> elements. <br/>
                                    </font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">Line 1 is mandatory</font>
                                    </li>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">A maximum of 4 address lines will be  present.<br/>
                                    <br/>
                                    </font>
                                    </li>
                                    </ul>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">A <i>postalCode</i> element to carry a  postcode (optional)</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">An <i>addressKey</i> element to carry a  PAF key (optional)</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="AD"/>
            </attribute>
        </class>
    </ownedClass>
