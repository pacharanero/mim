    <ownedClass>
        <class isAbstract="false" name="HealthspaceRegistration">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.73" shapeTemplate="Act">
                    <position x="4.20606" y="10.01388"/>
                    <size height="0.78112" width="3.3"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>
                                    <font face="times new roman,times" size="3">Details of the patient's registration status with HealthSpace.</font>
                                </strong>
                            </p>
                            <strong>
                                <font face="Times New Roman" size="3">
                                    <font face="Times New Roman"
                                    size="3">In addition to the attributes below, in order to control the update semantics, the following will also be present: <font
                                    face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3"/>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                </font>
                            </strong>
                            <strong>
                                <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">An <em>updateMode</em> attribute to indicate whether the item should be "added",</font>
                                    <font
                                    face="Times New Roman" size="3">"altered" or "removed".</font>
                                    </li>
                                    </ul>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                </font>
                            </strong>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Observation act.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
