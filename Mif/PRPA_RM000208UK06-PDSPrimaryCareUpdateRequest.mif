                <supplierDomainSpecification codingStrength="CNE" domainName="ASSIGNED"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <designComments>
                        <text>&lt;p&gt;NHAIS System ID&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The identifier of the NHAIS system to which the patient is registered, which is an NHAIS Cypher. This is carried in the following way: <ul>
                                    <li>The <em>root</em> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.6" </li>
                                    <li>the <em>extension</em> attribute will contain the ID of the NHAIS system, which is an NHAIS Cypher.</li>
                                    </ul>
                                    </font>
                                </p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
