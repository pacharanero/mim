    <ownedClass>
        <class isAbstract="false" name="DispensingAuthorisationReason">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.413" shapeTemplate="Act">
                    <position x="18.59998" y="14.97777"/>
                    <size height="0.78112" width="3.01227"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <b>When the PatientCareProvisionType is a GP Practice and the GP was given authorisation to act as a dispensary, this class hold the reason for being given authorisation.</b>
                            </p>
                            <p>
                                <b>This must be used in conjunction with the <i>updateMode</i> attribute of the <i>CareProviderPaymentInfo</i> class in the following way:</b>
                            </p>
                            <ul>
                                <li>
                                    <b>This class may be present where the <i>updateMode  </i>is set to 'added' or 'altered'</b>
                                </li>
                                <li>
                                    <b>This class must not be present where the <i>updateMode</i> is set to 'removed'.</b>
                                </li>
                            </ul>
                            <p>Note: Where the updateMode is set to "added" or "altered", at least one of the subject and pertinentInformation links and associated classes must be present (i.e. where Care Provider Payment data is being added or altered, at least one of Dispensing Authorisation Reason and Residential Institution code must be provided).</p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an observation. </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
