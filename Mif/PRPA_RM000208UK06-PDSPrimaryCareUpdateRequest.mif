            <attribute conformance="R" defaultValue="43" fixedValue="43"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates the type of observation. </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i> attribute will contain the fixed value shown. </li>
                                <li>The <i>codeSystem</i> attribute will contain the OID for the vocabulary</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The business effective date when this information was applicable, expressed as a range, supplied in the <i>low</i> and <i>high</i> attributes of the IVL_TS.</p>
                            <p>The dates are full date without time. </p>
                            <p>This attribute shall be used in conjunction with the <i>updateMode</i> of the CareProviderPaymentInfo class in the following way:</p>
                            <ul>
                                <li>This attribute shall be present if the <i>updateMode</i> is set to 'added' or 'altered'</li>
                                <li>If the <i>updateMode</i> is set to 'removed', the <i>low</i> attribute shall not be present, and the <i>high</i> attribute may optionally be present.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
