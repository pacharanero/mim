            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times" size="3">The value of the consent status.                                   </font>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">The <i>code</i> attribute will contain a value from the list of codes in the <u>Consent</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">The <i>codeSystem</i> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.2"</font>
                                    </li>
                                    </ul>
                                    </font>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="Consent"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="LanguageCommunication">
            <derivationSupplier className="LanguageCommunication" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.223" shapeTemplate="OtherClass">
                    <position x="13.27667" y="7.37445"/>
                    <size height="0.92223" width="2.61"/>
                </graphElement>
            </graphicRepresentation>
            <graphicRepresentation presentation="HL7Shadow">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.227" shapeTemplate="OtherClass">
                    <position x="17.91796" y="5.23889"/>
                    <size height="0.75" width="1.882"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>Parent class containing details of a person's language preferences, where the preferred language is not English. </b>
                        </p>
                        <b>WHEN THIS CLASS IS ASSOCIATED WITH A PATIENT ROLE: In order to control the update semantics, the following will also be present: <ul>
                                <li>An <i>updateMode</i> attribute to indicate whether the item should be "added", "altered" or "removed" (mandatory).</li>
                            </ul>
                            <p>WHEN THIS CLASS IS NOT ASSOCIATED WITH THE PATIENT:</p>
                        </b>
                        <ul>
                            <li>
                                <b>
                                    <p>No <i>updatemode </i>will exist in this class, the <i>updateMode </i>attribute from RelatedPersonRole will apply instead.<br/>
                                    </p>
                                </b>
                            </li>
                        </ul>
                        <p/>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="languageCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">
                                    <font face="Times New Roman" size="3">The Coded Only datatype flavour is used to carry this information as follows:</font>
                                    <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain a value from the list of codes in the <u>HumanLanguage</u> vocabulary.</font>
                                    </li>
                                    </ul>
                                    <p>
                                    <font face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>LanguageCommunication</em> in the following way:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</font>
                                    </li>
                                    </ul>
                                </font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="languageCode"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="HumanLanguage"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="proficiencyLevelCode" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">Indicates whether an interpreter is required for this person.</font>
                                    <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain a value from the list of codes in the <u>InterpreterRequired</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.39"</font>
                                    </li>
                                    </ul>
                                    <p>
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>LanguageCommunication</em> in the following way:</font>
                                    </font>
                                    <font face="Times New Roman" size="3">
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </font>
                                    </font>
                                    </li>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</font>
                                    </li>
                                    </ul>
                                    </font>
                                    </p>
                                </font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="proficiencyLevelCode"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="InterpreterRequiredIndicator"/>
            </attribute>
            <attribute defaultValue="true" fixedValue="true"
                isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="preferenceInd" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">Indicates whether that the language is preferred by the person.</font>
                                </font>
                                <font face="times new roman,times" size="3">
                                    <p>
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>LanguageCommunication</em> in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</li>
                                    </ul>
                                    </font>
                                    </p>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="preferenceInd"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
