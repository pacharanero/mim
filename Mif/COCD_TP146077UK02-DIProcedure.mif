            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>This is a unique identifier for this instance of a diagnostic imaging procedure. </p>
                            <p>The Identifier Global datatype flavour is used to carry the identifiers follows:</p>
                            <ul>
                                <li>The root attribute shall contain a DCE UUID. </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.uuid.mandatory"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A SnomedCT code from the DIProcedureSnCT vocabulary identifying the type of Diagnostic Imaging procedure. </p>
                            <p>The Concept Descriptor (CD) with CDA URL datatype/flavour shall be used to carry this information as follows: </p>
                            <ul>
                                <li>The <i>code</i> attribute shall contain a code from the relevant vocabulary </li>
                                <li>The <i>codeSystem</i> attribute shall contain the OID for SnomedCT </li>
                                <li>The <i>displayName</i> attribute shall carry a description associated with the code in SnomedCT </li>
                                <li>The <i>originalText</i> element can be used to carry a <i>reference</i>element. This can link the coded item to the relevant text in the CDA section </li>
                                <li>
                                    <i>qualifier </i>(s) may be used if required </li>
                            </ul> Note the implementation guidance for the domain where this template is used should be consulted regarding correct usage of the <i>originalText</i> element.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CD"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DIProcedureSnCT"/>
            </attribute>
            <attribute conformance="R" defaultValue="completed"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="statusCode" sortKey="9">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The status of the Diagnostic Imaging Procedure. </p>
                            <p>The Coded Only data type flavour is used to carry this information as follows:<br/>
                            </p>
                            <ul>
                                <li>The <i>code</i> attribute will contain a one of the following codes from the Act Status vocabulary: </li>
                            </ul>
                            <blockquote>
                                <ul>
                                    <li>nullified </li>
                                    <li>completed. </li>
                                    <li>active</li>
                                </ul>
                            </blockquote>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="statusCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ActStatus"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The date and time performed.</p>
                            <p>The date range shall be carried as follows: </p>
                            <p>If both a start date and an end date are present the Date or Time Interval Complete datatype shall be used:</p>
                            <ul>
                                <li>The <em>low</em> attribute shall contain the start date </li>
                                <li>The <em>high</em> attribute shall contain the end date. </li>
                            </ul>
                            <p>If only a start date is present the Date or Time Interval After datatype shall be used:</p>
                            <ul>
                                <li>The <em>low</em> attribute shall contain the start date.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
