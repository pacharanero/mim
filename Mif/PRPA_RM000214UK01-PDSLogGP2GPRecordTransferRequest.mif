            <attribute conformance="R" defaultValue="EHR"
                fixedValue="EHR" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>  Indicates the type of observation.<br/>
                                <br/> In this case, the observation is that of the type of record transfer for the patient.  </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:      </p>
                            <ul>
                                <li>The <i>code</i> attribute will contain the value "EHR" from the <u>RecordTransferType</u> vocabulary</li>
                                <li>The <i>codeSystem</i> attribute will contain the OID for <u>RecordTransferType</u>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="RecordTransferType"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The date of the electronic record transfer.</p>
                            <p>The format of this attribute is Date and Time, in the format YYYYMMDDHHMM. </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
        </class>
