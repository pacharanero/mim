    <ownedEntryPoint className="PdsRequest" id="PRPA_RM000214UK01"
        isAbstract="false" name="LogGP2GPRecordTransferRequest">
        <annotations>
            <description>
                <text>
                    <p>To record the transfer of the  Electronic Health Record on the Spine,</p>
                    <p>invoked when a GP2GP EHR Extract is received at the GP practice.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text/>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="PRPA_RM000214UK01">
                <position x="4.44095" y="0.02778"/>
                <size height="0.58611" width="3.46474"/>
                <anchorage connectToShapeId="Sheet.1">
                    <position x="6.17332" y="0.61389"/>
                    <graphEdge>
                        <anchor>
                            <position x="6.17332" y="1.15021"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
