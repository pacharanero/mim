        <class isAbstract="false" name="RequestingSystem">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.75" shapeTemplate="Role">
                    <position x="9.0" y="6.57165"/>
                    <size height="0.51445" width="2.66147"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>New Vocab, where SystemRole with a  value of Snd is a sending system,</p>
                        <p>and that of Rcv is a receiving system.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.96">
                            <position x="5.037" y="7.37165"/>
                            <size height="0.5" width="3.65603"/>
                            <anchorage connectToShapeId="Sheet.75">
                                <position x="6.86502" y="7.62165"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="9.79844" y="7.0861"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <b>The role of the requesting device, where the device is a NCRS compliant GP system.<br/>
                        </b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="ROL"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>  	  Indicates that this is a role. </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ROL"/>
            </attribute>
            <attribute conformance="R" defaultValue="REQ"
                fixedValue="REQ" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>  	  Indicates this is the requesting NCRS compliant GP system .  </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code </i>attribute will contain the value "REQ" from the list of codes in the <u>SystemRoleType</u> vocabulary <br/>
                                </li>
                                <li>The <i>codeSystem </i>attribute will contain the OID for <u>SystemRoleType</u> vocabulary  </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SystemRoleType"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
