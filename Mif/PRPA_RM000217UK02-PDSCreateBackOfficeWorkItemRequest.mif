    <ownedClass>
        <class isAbstract="false" name="GenderReassignmentRequest">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="false"
                    shapeId="Sheet.31" shapeTemplate="Act">
                    <position x="29.86232" y="8.13371"/>
                    <size height="0.76111" width="3.07097"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>Details of the patient's Gender Reassignment Request, populated with the patient's new requested identity.  </b>
                        </p>
                        <p>
                            <b>This class should only be present if the work item type being requested is "investigateGender". It must not be present otherwise.</b>
                            <br/>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="REG"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is a registration act.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="REG"/>
            </attribute>
            <attribute conformance="R" fixedValue="RQO"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is a request.<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="RQO"/>
            </attribute>
            <attribute conformance="R" defaultValue="05" fixedValue="05"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>  	 Indicates the type of registration.<br/>
                                <br/>In this case, it is the registration of Gender Reassignment with the Primary Care Registration Back Office. <br/>
                                <br/>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The<i> cod</i>e attribute will contain the value "04" (Gender Reasssignment) from the list of codes in the <u>DemographicRegistrationType</u> vocabulary</li>
                                <br/>
                                <li>The<i> codeSystem</i> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.165"   </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicRegistrationType"/>
            </attribute>
        </class>
    </ownedClass>
