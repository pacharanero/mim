    <ownedClass>
        <class isAbstract="false" name="Patient">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="false"
                    shapeId="Sheet.11" shapeTemplate="Role">
                    <position x="25.96273" y="8.41092"/>
                    <size height="1.02363" width="1.84658"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>A class used to hold details of the patient<br/>
                        </b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an patient role.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The NHS number of the patient.<br/>
                            </p>
                            <p>When the request type is to do with confusion or duplicates then this NHS number MUST be the same as carried in the primary DuplicatePatient.id or ConfusionPatient.id therefore indicating which of the 1 to 5 DuplicatePatient or ConfusionPatient ids is the primary id.</p>
                            <p>When the request type is to do with gender reassignment requests then this will contain the current NHS number </p>
                            <p>This will be one of:      </p>
                            <ul>
                                <li>NHS Number     </li>
                            </ul>
                            <ul>
                                <li>Old Format NHS Number     </li>
                            </ul>
                            <ul>
                                <li>Temporary NHS Number (issued by an NHAIS registration authority)  </li>
                            </ul>
                            <p>The Identifier External datatype flavour is used to carry this information as follows:  </p>
                            <p>If it is an NHS Number:      </p>
                            <ul>
                                <li>The <i>root </i>attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.1"     </li>
                            </ul>
                            <ul>
                                <li>The <i>extension </i>attribute will contain the NHS Number <br/>
                                </li>
                            </ul>
                            <p>If it is an Old Format or Temporary NHS Number:      </p>
                            <ul>
                                <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.3"                                    </li>
                            </ul>
                            <ul>
                                <li>The <i>extension </i>attribute will contain the Old Format or Temporary NHS Number </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
