            <annotations>
                <constraint name="code">
                    <text>
                        <p>No more than one instance</p>
                        <p>of each code allowed</p>
                        <p>Allowed values =</p>
                        <p>58,59,60,61 and 62</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.498">
                            <position x="2.94294" y="13.94566"/>
                            <size height="0.67778" width="1.51413"/>
                            <anchorage connectToShapeId="Sheet.291">
                                <position x="3.7" y="14.28455"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="5.9" y="13.92344"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </constraint>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>A class used to carry boolean values to indicate 1 or more of the following</b>
                        </p>
                        <ul>
                            <li>
                                <b>Whether the case is deemed clinically urgent</b>
                            </li>
                            <li>
                                <b>Whether the confusion patient is under long term care</b>
                            </li>
                            <li>
                                <b>Whether the confusion patient has previously been the subject of confusion</b>
                            </li>
                            <li>
                                <b>Whether the confusion patient is incorrectly marked as dead</b>
                            </li>
                            <li>
                                <b>Whether the patient is aged 5 years or under</b>
                            </li>
                        </ul>
                        <p>
                            <b>The value carried in ConfusionInformation.value should be identified by the code contained in ConfusionInformation.code</b>
                        </p>
                        <p>
                            <b>0 to 5 instances of this class may be present but no more than 1 instance of this class shall be present with the same coded value.</b>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an observation. </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an event.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div contenteditable="false" style="height: 100%; width: 100%">
                                    <div>
                                    <p>A code from the vocabulary shown indicating the type of demographic observation that the boolean carried in the value attribute represents.<br/>
                                    </p>
                                    <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                                    <ul>
                                    <li>The <i>code</i> attribute shall contain the value.                                                       </li>
                                    <li>The <i>code System</i> attribute shall contain the OID for the vocabulary  concerned.</li>
                                    </ul>
                                    </div>
                                    <div>
                                    <b>No more than one instance of each allowed code allowed.</b>
                                    </div>
                                    <div>
                                    <b>Allowed values are 58,59,60,61 and 62 </b>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A boolean value to indicate whether or not one of the following is true or false dependant on the value carried in the code attribute.<br/>
                            </p>
                            <ul>
                                <li> the case is deemed clinically urgent</li>
                                <li> the confusion patient is under long term care</li>
                                <li> the confusion patient has previously been the subject of confusion</li>
                                <li> the confusion patient is incorrectly marked as dead</li>
                                <li> the patient is aged 5 years or under</li>
                            </ul>
                            <p/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
    </ownedClass>
