                <annotations>
                    <otherAnnotation type="html">
                        <text>A code from the vocabulary shown indicating the type of demographic observation.<br/>
                            <br/>The Coded with Code System datatype flavour is used to carry this information as follows:<br/>
                            <br/>
                            <ul>
                                <li>The code attribute shall contain the value.</li>
                                <li>The code System attribute shall contain the OID for the vocabulary concerned.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>The date or date range when the armed forces information is / was applicable.<br/>
                            <br/>The Date Only datatype flavour shall be used.<br/>
                            <br/>If both a start date and an end date are present:<br/>
                            <br/>
                            <ul>
                                <li>The low attribute shall contain the start date.</li>
                                <li>The high attribute shall contain the end date.</li>
                            </ul>
                            <br/>If only a start date is present:<br/>
                            <br/>
                            <ul>
                                <li>The low attribute shall contain the start date.</li>
                            </ul>
                            <br/>If only an end date is present:<br/>
                            <br/>
                            <ul>
                                <li>The high attribute shall contain the end date.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
