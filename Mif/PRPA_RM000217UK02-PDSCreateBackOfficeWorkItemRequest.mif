    <ownedEntryPoint className="PdsRequest" id="PRPA_RM000217UK02"
        isAbstract="false" name="PDS Create Back Office Work Item Request">
        <annotations>
            <description>
                <text>
                    <p>This message allows a GP Practice to notify a Primary Care</p>
                    <p>Registration Back Office (PCRBO) of the need to raise a work item.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text>
                    <b>A class for providing information about a GP practice's request to notify a Primary Care Registration Back Office (PCRBO)                      to raise a work item.</b>
                </text>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="PRPA_RM000217UK02">
                <position x="25.52222" y="3.03733"/>
                <size height="0.58611" width="3.41488"/>
                <anchorage connectToShapeId="Sheet.1">
                    <position x="27.22966" y="3.62344"/>
                    <graphEdge>
                        <anchor>
                            <position x="27.22966" y="4.12344"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
    <ownedClass>
        <class isAbstract="false" name="PdsRequest">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
