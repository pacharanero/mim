                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this a person entity.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this Entity represents a distinct single instance.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The name of the person who is the duplicate or confusion patient's father.</p>
                            <p>The particular flavour of the person name datatype used here is "Person name structured with use" but only the attributes detailed here are used.<br/>
                            </p>
                            <p>The <i>"use"</i> attribute is <b>mandatory</b>
                                <br/>
                            </p>
                            <p>Any instance of this attribute shall be identified the following way</p>
                            <p>The use shall be stated as   </p>
                            <ul>
                                <li>  		  "L" - Usual        (current) name</li>
                            </ul>
                            <p>When the use is "usual" then</p>
                            <ul>
                                <li>There maybe 1 instance of family to hold the fathers Surname</li>
                                <li>There maybe up to 2 instances of given to hold the fathers forename and other forename </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="PN"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="birthTime" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div style="height: 100%; width: 100%">
                                    <div>
                                    <p>To provide the date the duplicate or confusion patient's father was born.</p>
                                    <div contenteditable="false" style="height: 100%; width: 100%">
                                    <div style="height: 100%; width: 100%">
                                    <div>
                                    <p>The date must be given in the following format:</p>
                                    <ul>
                                    <li>YYYYMMDD  </li>
                                    </ul>
                                    <p>The Date Only datatype  flavours is used to carry this information as follows:</p>
                                    <ul>
                                    <li>The <i>value</i> attribute will contain the date value. </li>
                                    </ul>
                                    </div>
                                    </div>
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="birthTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
        </class>
