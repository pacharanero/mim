                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this Entity represents a distinct single instance.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Organization" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A valid SDS identifier that uniquely identifies the Organization. </p>
                            <p>The SDS Organisation ID of the registering authority responsible for removing or updating the VPI indicator.<br/>
                            </p>
                            <p> The Identifier External datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID for the appropriate level of organisation.                                </li>
                                <li>The <i>extension</i> attribute will contain the identifier.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Organization" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.Organization.oid.mandatory"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code from the vocabulary shown to indicate the type of registering authority.<br/>
                            </p>
                            <p>The Coded with Code System flavour of Coded Value (CV) datatype shall be used to carry this information  as follows:</p>
                            <ul>
                                <li>The <em>code</em> attribute shall contain the value.                           </li>
                                <li>The <em>code System</em> attribute shall contain the OID for the vocabulary  concerned.                          </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Organization" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="RegisteringAuthorityType"/>
            </attribute>
        </class>
    </ownedClass>
