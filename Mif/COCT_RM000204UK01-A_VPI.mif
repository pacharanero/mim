            <attribute conformance="R" defaultValue="AP" fixedValue="AP"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="contextControlCode" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Specifies how the author contributes to the context of the VPI and whether it may be propagated to descendent                            acts whose association allows such propagation.                          </p>
                                <p>"A" (Additive)- the association adds to any context of the same or more specific type that has been conducted from the parent                            act.                          </p>
                            </div>                                            "P" (Propagating)- the association is conducted to all child acts where the ActRelationship.contextConductionInd is set to                         "true" - where not stated this defaults to "true".</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="contextControlCode"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ContextControl"/>
            </attribute>
        </class>
