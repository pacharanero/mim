            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="negationInd" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates whether or not the target role is indeed a subject of the VPI.</p>
                            <p>If set to 'false', indicates that the VPI applies to the patient. If set to 'true', indicates that the VPI does not apply to the patient.</p>
                            <p>At least one of the participations <i>subject</i>, <i>subject1</i>, <i>subject2 </i>and <i>subject3 </i>must have a negationInd set to 'false'. <br/>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="negationInd"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
