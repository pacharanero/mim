                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div contenteditable="false" style="height: 100%; width: 100%">
                                    <div>
                                    <p>A code from the vocabulary shown indicating the type of act.<br/>
                                    </p>
                                    <p>The  Coded Plain flavour of Coded Value (CV) datatype shall be used to carry this information  as follows:</p>
                                    <ul>
                                    <li>The <i>code</i> attribute shall contain the value.                                                       </li>
                                    <li>The <i>code System</i> attribute shall contain the OID for the vocabulary  concerned.                                                     </li>
                                    </ul>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The business effective date for which this data is applicable.</p>
                            <p>Both a start date and an end date are mandatory and the Date or Time  Interval Complete data type shall be used: </p>
                            <ul>
                                <li>The <em>low</em> attribute shall contain the start date from which the hearing set the indicator.                                                    </li>
                                <li>The <em>high</em> attribute shall contain the expiry date of the VPI.                                                    </li>
                            </ul>
                            <p/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code from the vocabulary shown to indicate the type of Violence Classification. <br/>
                            </p>
                            <p>The Coded with Code System flavour of Coded Value (CV) datatype shall be used to carry this information  as follows:</p>
