			<attribute conformance="R" isMandatory="true" maximumMultiplicity="1" minimumMultiplicity="1" name="moodCode" sortKey="2" isStructural="true">
				<annotations>
					<otherAnnotation type="html">
						<text>
							<div contenteditable="false" style="height: 100%; width: 100%">
								<div>
									<p>The mood code of the Assessment Event. </p>
									<p>The value of mood code should be set according to the information and context  of the coded entry information being carried                         in the assessment class.                       </p>
									<p>The CodedOnly datatype flavour is used to carry this information as  follows:</p>
									<ul>
										<li>The <i>code</i> attribute will contain a value from the list of codes in  the x_DocumentEncounterMood vocabulary.                          </li>
									</ul>
								</div>
							</div>
						</text>
					</otherAnnotation>
				</annotations>
