			<attribute conformance="R" defaultValue="COCD_TP146065UK02#careSetting" fixedValue="COCD_TP146065UK02#careSetting" isMandatory="true" maximumMultiplicity="1" minimumMultiplicity="1" name="templateId" sortKey="0">
