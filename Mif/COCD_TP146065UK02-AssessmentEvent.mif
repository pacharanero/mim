				<annotations>
					<otherAnnotation type="html">
						<text>
							<div>
								<p>A SnomedCT code specifying the care setting.. </p>
								<p>The Coded Plain flavour of the CodedValue (CV) datatype shall be used to  carry this information as follows:</p>
								<ul>
									<li>The <i>code</i> attribute shall contain a value from the list of codes in  the vocabulary  </li>
									<li>The <i>codeSystem</i> attribute shall containthe OID for SnomedCT  </li>
									<li>The <i>displayName</i> attribute will carry a description for the code  from the coding system </li>
								</ul>
							</div>
						</text>
					</otherAnnotation>
				</annotations>
				<derivationSupplier attributeName="code" className="Role" staticModelDerivationId="1"/>
				<type name="CV"/>
				<supplierDomainSpecification codingStrength="CNE" domainName="CDACareSettingTypeSnCT"/>
			</attribute>
		</class>
