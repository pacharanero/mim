            <attribute conformance="R" defaultValue="4" fixedValue="4"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times"
                                    size="3">A code to indicate the type of consent. <font
                                    face="times new roman,times" size="3"/>
                                </font>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">The <i>code</i> attribute will contain a value from the list of codes in the <u>DemographicConsentObservationType</u> vocabulary</font>
