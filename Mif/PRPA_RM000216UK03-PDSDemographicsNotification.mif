    <ownedClass>
        <class isAbstract="false" name="NHAISRegistrationEvent">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.131" shapeTemplate="Act">
                    <position x="11.32392" y="5.86344"/>
                    <size height="0.78112" width="3.00608"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>Information relating to the registration of a patient's details onto an NHAIS system.<br/>
                            <br/> In the case of a Registration Notification the NHAIS Posting instance will hold details of the previous (last known) NHAIS Posting. In the case of all other Notifications the NHAIS Posting instance will hold details of the current (current effective) NHAIS Posting.<br/>
                        </b>
                        <span id="XSLTPageNoTree123:XSLTOut">
                            <p>
                                <b>In addition to the attributes below, in order to specify the type of update that has occurred, the following will also be present: </b>
                            </p>
                            <ul>
                                <li>
                                    <b> An <i>updateMode</i> attribute to indicate whether the item has been "added", "altered", "removed" or is "unchanged"</b>
                                    <b> (mandatory)</b>
                                </li>
                            </ul>
                        </span>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="REG"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a Registration act.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="REG"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Event.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="01" fixedValue="01"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">Indicates the type of registration. In this case, it is the registration of a record onto an NHAIS system.</font>
                                </font>
                                <font face="times new roman,times" size="3">
                                    <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain the value "01" (NHAIS Registration) from the list of codes in the <u>DemographicRegistrationType</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.165"</font>
                                    </li>
                                    </ul>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicRegistrationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <div>The time period in which the information is valid, represented as a range, supplied in the <i>low</i> and <i>high</i> sub-elements. Both the <i>low</i> and <i>high</i> sub-elements are optional, allowing open-ended ranges to be specified.<br/>
                                </div>
                                <p>The particular flavour of the timestamp datatype used here is Date Only. This means that the dates must be in the format YYYYMMDD.</p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
