    <ownedClass>
        <class isAbstract="false" name="PatientRole">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="false"
                    shapeId="Sheet.1" shapeTemplate="Role">
                    <position x="5.58973" y="5.13289"/>
                    <size height="7.52223" width="3.02919"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <strong>
                                <font face="times new roman,times" size="3">Parent class linking to and containing information about a patient.</font>
                            </strong>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a Patient role.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <font face="times new roman,times" size="3">
                                <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="times new roman,times" size="3">The current NHS number of the patient. This will be one of:</font>
                                </div>
                                <ul>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">NHS Number</font>
                                    </div>
                                    </li>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">Old Format NHS Number</font>
                                    </div>
                                    </li>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">Temporary NHS Number (issued by an NHAIS registration authority)</font>
                                    </div>
                                    </li>
                                </ul>
                                <p class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The Identifier External datatype flavour is used to carry this information as follows:</font>
                                </p>
                                <p class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">If it is an NHS Number:</font>
                                </p>
                                <ul>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>root</em> attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.1"</font>
                                    </div>
                                    </li>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>extension</em> attribute will contain the NHS Number</font>
                                    </div>
                                    </li>
                                </ul>
                                <p class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">If it is an Old Format or Temporary NHS Number:</font>
                                </p>
                                <ul>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>root</em> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.3"</font>
                                    </div>
                                    </li>
                                    <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>extension</em> attribute will contain the Old Format or Temporary NHS Number</font>
                                    </div>
                                    </li>
                                </ul>
                                <p class="63C7BF90-553E-11DB-A2A2-929938389B48">NB This attribute is used for matching only and cannot be updated.</p>
                            </font>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="addr" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Address of the patient.</p>
                            <p>The particular flavour of the address datatype used here is Address streetAddressLine Typed (format 2 in the datatypes description), plus: </p>
                            <ul>
                                <li>Optional Postcode</li>
                                <li>Optional Address Key</li>
                                <li>Mandatory Use</li>
                                <li>Optional Useable Period<br/>
                                </li>
                            </ul>
                            <p>This means that the address will contain the following components:</p>
                            <ul>
                                <li>Between one and five <i>streetAddressLine</i> elements. Excludes postcode, may be vernacular or PAF-derived. For vernacular addresses, the following formatting convention should be used: <ul>
                                    <li>Line 1: premises ID</li>
                                    <li>Line 2: no. / thoroughfare</li>
                                    <li>Line 3: locality</li>
                                    <li>Line 4: post town</li>
                                    <li>Line 5: county</li>
                                    <li>Lines 1 or 2 and line 4 are mandatory</li>
                                    </ul>
                                </li>
                                <li>A <i>postalCode</i> element to carry a postcode (<i>optional</i>) </li>
                                <ul>
                                    <li>This UK format Postcode, 8 character string, e.g. ZZ99 3VZ (as per BS7666 standard). <br/>
                                    </li>
                                    <li>The 8 characters field allows a space to be inserted to differentiate between the inward and outward segments of the code, enabling full use to be made of Royal Mail postcode functionality. </li>
                                </ul>
                                <li>An <i>addressKey</i> element to carry a PAF key (Postcode Address File). PAF is a data file available from the Royal Mail(<i>optional</i>)</li>
                                <li>The <i>use</i> attribute to denote the type of address. Only value "H" Home (Usual) address is permissible here (<i>mandatory</i>) </li>
                            </ul>
                            <p>
                                <b>NB</b> The useablePeriod element of the AD dataType should be used to convey the Business Effective Dates, which are full dates without time. These are dates for which this data is/was current as a range, supplied in the Low and High attributes of the IVL_TS.</p>
                            <span id="XSLTPageNoTree123:XSLTOut">
                                <p> Additionally, in order to specify the type of update that has occurred, the following will also be present: </p>
                                <ul>
                                    <li> An <i>updateMode</i> attribute to indicate whether the item has been "added", "altered", "removed" or is "unchanged" (mandatory)</li>
                                </ul>
                            </span>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="addr"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="AD"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="*"
                minimumMultiplicity="0" name="telecom" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Telecommunication address(es) of the patient. </p>
                            <p>The valid flavour of the TEL datatype used here is:</p>
                            <ul>
                                <li>
                                    <p>Telecommunication address plus use <i>(f)</i>
                                    </p>
                                </li>
                            </ul>
                            <p>This means that the telecommunication address will contain the following components:</p>
                            <ul>
                                <li>The value attribute to carry the telecommunication number or address <i>(mandatory). <br/>
                                    </i>
                                </li>
                                <ul>
                                    <li>This is expressed as a URL, where the contact method and number are separated by a colon (i.e. "tel:01234 567890") <br/>
                                    </li>
                                    <li>The URL scheme is mandatory and must be one of the following values: <br/>
                                    </li>
                                    <ul>
                                    <li>tel: <br/>
                                    </li>
                                    <li>fax: <br/>
                                    </li>
                                    <li>mailto: <br/>
                                    </li>
                                    <li>textphone: (This is not an officially-registered URI scheme)</li>
                                    </ul>
                                </ul>
                            </ul>
                            <ul>
                                <li>The use attribute to denote the type of telecommunication address (<i>mandatory</i>) </li>
                            </ul>
                            <ul>
                                <li>The useablePeriod element of the TEL dataType should be used to convey the Business Effective Dates, which are full dates without time (<i>optional</i>)<br/>
                                </li>
                                <ul>
                                    <li>These are dates for which this data is/was current as a range, supplied in the Low and High attributes of the IVL_TS.</li>
                                </ul>
                            </ul>
                            <br/> Additionally, in order to specify the type of update that has occurred, the following will also be present: <ul>
                                <li>An <i>updateMode</i> attribute to indicate whether the item has been "added", "altered", "removed", or is "unchanged" (mandatory)</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="telecom"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="TEL" typeSpecialisation="TEL.NPFIT.use.required"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="confidentialityCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>To indicate the nature of any sensitive information about the patient in coded form.<br/>
                                    <br/> The Coded with Code System datatype flavour is used to carry this information as follows: </p>
                                <ul>
                                    <li>The code attribute will contain a value from the list of codes in the InformationSensitivity vocabulary; </li>
                                </ul>
                                <ul>
                                    <li>The codeSystem attribute will contain the OID referenced in the InformationSensitivity vocabulary.</li>
                                </ul>
                                <span id="XSLTPageNoTree123:XSLTOut"> Additionally, in order to specify the type of update that has occurred, the following will also be present: <ul>
                                    <li>An <i>updateMode</i> attribute to indicate whether the item has been "added", "altered", "removed", or is "unchanged" (mandatory)</li>
                                    </ul>
                                </span>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="confidentialityCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="InformationSensitivity"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
