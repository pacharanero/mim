    <ownedEntryPoint className="RegistrationEvent"
        id="PRPA_RM000216UK03" isAbstract="false" name="PdsDemographicsNotification">
        <annotations>
            <description>
                <text>
                    <p>The Demographics Notification will represent the following notification types:</p>
                    <p>registration, change, merge, removal, pending removal and cancelled pending removal.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text/>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
