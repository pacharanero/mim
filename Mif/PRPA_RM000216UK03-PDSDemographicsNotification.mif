    <ownedClass>
        <class isAbstract="false" name="TransferStatus">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.167" shapeTemplate="Act">
                    <position x="17.99242" y="5.02345"/>
                    <size height="0.91445" width="3.04742"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <b>The transfer status of a patient's paper medical record.</b>
                            </p>
                            <p/>
                            <p>
                                <span id="XSLTPageNoTree123:XSLTOut">
                                    <p>
                                    <b>In addition to the attributes below, in order to specify the type of update that has occurred, the following will also be present: </b>
                                    </p>
                                    <ul>
                                    <li>
                                    <b> An <i>updateMode</i> attribute to indicate whether the item has been "added", "altered", "removed" or is "unchanged"</b>
                                    <b> (mandatory)</b>
                                    </li>
                                    </ul>
                                </span>
                            </p>
                            <p/>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an Observation act.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an Event.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="19" fixedValue="19"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p> Indicates the type of observation. In this case, the observation is that of the transfer status of a patient's paper medical record. </p>
                                <p>The Coded with Code System datatype flavour is used to carry this information as follows: </p>
                                <ul>
                                    <li>The <em>code </em>attribute will contain the value "19" (Paper record transfer status) from the list of codes in the <u>DemographicObservationType</u> vocabulary </li>
                                </ul>
                                <ul>
                                    <li>The <em>codeSystem </em>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.35" </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="priorityCode" sortKey="13">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">The priority of the  transfer.</font>
                            </p>
                            <p>
                                <font face="Times New Roman" size="3">The Coded with Code System datatype  flavour is used to carry this information as follows:</font>
                            </p>
                            <ul>
                                <li>
                                    <font face="Times New Roman" size="3">The <i>code</i> attribute will contain  a value from the list of codes in the <u>PaperRecordTransferPriority  </u>vocabulary</font>
                                </li>
                                <li>
                                    <font face="Times New Roman" size="3">The <i>codeSystem</i> attribute will  contain the OID "2.16.840.1.113883.2.1.3.2.4.17.190"</font>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="priorityCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PaperRecordTransferPriority"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The transfer status of the paper record, also known as Paper Record Transfer  Flag.</p>
                            <p>The Coded with Code System datatype flavour is used to carry this information  as follows:</p>
                            <ul>
                                <li>The <em>code </em>attribute will contain a value from the list of codes in  the <u>PaperRecordTransferFlag </u>vocabulary </li>
                            </ul>
                            <ul>
                                <li>The <em>codeSystem </em>attribute will contain the OID  "2.16.840.1.113883.2.1.3.2.4.17.167"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PaperRecordTransferFlag"/>
            </attribute>
        </class>
    </ownedClass>
