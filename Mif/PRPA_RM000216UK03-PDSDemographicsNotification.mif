            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Person">
            <derivationSupplier className="Person" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="true"
                    shapeId="Sheet.17" shapeTemplate="Entity">
                    <position x="10.0" y="10.38066"/>
                    <size height="1.2" width="2.548"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <strong>
                                <font face="times new roman,times" size="3">Parent class linking to and containing information about a patient which is specific to the person.</font>
                            </strong>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PSN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a Person entity.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Instance of a person.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">Name(s) of the person. </font>
                                </p>
                                <p>
                                    <font face="times new roman,times" size="3">The particular flavour of the person name datatype used here is Person name structured with use (number 6 in the datatypes description). This means that the name will contain the following components: </font>
                                </p>
                                <ul>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <i>family</i> element to carry the surname or family name of the person (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">Up to 2 <i>given</i> elements to carry the given names of the person. If the person has more than 2 given names, these will be concatenated in the second given name attribute with a space between each name. The order of the elements is also significant, so the first occurrence of the <i>given</i> element will carry the first given name, and the second occurrence will carry the second, third, etc. given names (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <i>prefix</i> element to carry a prefix for the name, such as Mr, Mrs, etc. (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <i>suffix</i> element to carry a suffix for the name, such as Jnr, Snr, etc. (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A<i> use</i> attribute to denote the type of name. Only value "L"- Usual (Current) name is permissible here (mandatory) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <i>validTime</i> element to contain the dates for which the name is / was current as a range, supplied in the <i>low</i> and <i>high</i> sub-elements. Both the <i>low</i> and <i>high</i> sub-elements are optional, allowing open-ended ranges to be specified. The particular flavour of the timestamp datatype used here is Date Only. This means that the dates must be in the format YYYYMMDD. (optional)</font>
                                    </li>
                                </ul>
                                <span id="XSLTPageNoTree123:XSLTOut">
                                    <p> Additionally, in order to specify the type of update that has occurred, the following will also be present: </p>
                                    <ul>

                                    <li> An <i>updateMode</i> attribute to indicate whether the item has been "added", "altered", "removed" or is "unchanged" (mandatory<font size="3">
                                    <font face="Times New Roman">)</font>
                                    </font>
                                    </li>
                                    </ul>
                                </span>
                                <font face="Times New Roman" size="3"/>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="PN"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="AssignedOrganization">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
