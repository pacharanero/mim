    <ownedClass>
        <class isAbstract="false" name="PatientCareProvision">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.81" shapeTemplate="Act">
                    <position x="3.843" y="6.75644"/>
                    <size height="0.78112" width="2.628"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Code indicates the type of patient care provision,</p>
                        <p>for example, primary care or nominated pharmacy.</p>
                        <p>Effective time is not used for pharmacy.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.98">
                            <position x="6.90289" y="6.86906"/>
                            <size height="0.58889" width="2.54422"/>
                            <anchorage connectToShapeId="Sheet.81">
