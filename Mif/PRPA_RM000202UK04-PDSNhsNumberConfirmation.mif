                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a subject.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SBJ"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Person">
            <derivationSupplier className="Person" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.21" shapeTemplate="Entity">
                    <position x="7.544" y="4.90011"/>
                    <size height="1.04778" width="2.548"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div class="869DE630-584E-11DB-A42D-9C77C76CC4C4">
                            <strong>
                                <font face="times new roman,times" size="3">Parent class linking to and containing information about a patient which is specific to the person.</font>
                            </strong>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PSN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="22D114F0-584F-11DB-A453-9C77C76CC4C4">
                                <font face="times new roman,times" size="3">Indicates that this is a Person entity.</font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="58D64660-584F-11DB-A455-9C77C76CC4C4">
                                <font face="times new roman,times" size="3">Indicates that this is an Instance of a person.</font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="*"
                minimumMultiplicity="0" name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">Name(s) of the person. </font>
                                </p>
                                <p>
                                    <font face="times new roman,times" size="3">The particular flavour of the person name datatype used here is Person name structured with use (number 6 in the datatypes description). This means that the name will contain the following components: </font>
                                </p>
                                <ul>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>family</em> element to carry the surname or family name of the person (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">Up to 2 <em>given</em> elements to carry the given names of the person. If the person has more than 2 given names, these will be concatenated in the second given name attribute with a space between each name. The order of the elements is also significant, so the first occurrence of the <em>given</em> element will carry the first given name, and the second occurrence will carry the second, third, etc. given names (optional)</font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>prefix</em> element to carry a prefix for the name, such as Mr, Mrs, etc. (optional)</font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>suffix</em> element to carry a suffix for the name, such as Jnr, Snr, etc. (optional)</font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A<em> use</em> attribute to denote the type of name. Only the values "L" (usual), "A" (alias) and "PREFERRED" (preferred) are permitted here (mandatory)</font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>validTime</em> element to contain the dates for which the name is / was current as a range, supplied in the <em>low</em> and <em>high</em> sub-elements. Only current and future dated names are provided here. (optional)</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="PN"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="administrativeGenderCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The administrative gender of the person.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The Coded Only datatype flavour is used to carry this information as follows:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain a value from the list of codes in the <u>Sex</u> vocabulary.</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier
                    attributeName="administrativeGenderCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="Sex"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="birthTime" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The date of birth of the person.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The particular flavours of the timestamp datatype allowed here are:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">Date Only</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Date Month</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Date Year</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="birthTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="deceasedTime" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">The date and time of death of the person.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="deceasedTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
        </class>
    </ownedClass>
