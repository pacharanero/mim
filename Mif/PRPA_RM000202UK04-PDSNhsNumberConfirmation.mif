    <ownedEntryPoint className="PdsNhsNumberConfirmation"
        id="PRPA_RM000202UK04" isAbstract="false" name="PdsNhsNumberConfirmation">
        <annotations>
            <description>
                <text>
                    <p>A positive response to the confirm NHS Number query.</p>
                    <p>A number of PDS data fields are output as part of the response, to</p>
                    <p>reduce the need for additional queries immediately following confirmation.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text/>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="PRPA_RM000202UK04">
                <position x="3.2448" y="0.02756"/>
                <size height="0.71944" width="3.73041"/>
                <anchorage connectToShapeId="Sheet.1">
                    <position x="5.11" y="0.747"/>
                    <graphEdge>
                        <anchor>
                            <position x="5.11" y="1.181"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
    <ownedClass>
        <class isAbstract="false" name="PdsNhsNumberConfirmation">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.1" shapeTemplate="Act">
                    <position x="4.321" y="1.181"/>
                    <size height="0.75" width="1.99"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <font face="times new roman,times" size="3">
                                <strong>Parent class linking to details returned in the confirmation query response. As well as confirming that the NHS number specified in the query exists on the PDS, a number of data fields are also retrieved from the PDS.</strong>
                            </font>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Observation act.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Event.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="PatientRole">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="true"
                    shapeId="Sheet.5" shapeTemplate="Role">
                    <position x="4.479" y="2.547"/>
                    <size height="2.281" width="3.03"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div class="FCE96DC0-552C-11DB-85E0-EE1AC0A5204E">
                            <strong>
                                <font face="times new roman,times" size="3">Parent class linking to and containing information about a patient.</font>
                            </strong>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="CC1F8A70-552D-11DB-9F8D-929938389B48">
                                <font face="times new roman,times" size="3">Indicates that this is a Patient role.</font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                <font face="times new roman,times" size="3">The current NHS number of the patient. This will be one of:</font>
                            </div>
                            <ul>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">NHS Number</font>
                                    </div>
                                </li>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">Old Format NHS Number</font>
                                    </div>
                                </li>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">Temporary NHS Number (issued by an NHAIS registration authority)</font>
                                    </div>
                                </li>
                            </ul>
                            <p class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                <font face="Times New Roman" size="3">The Identifier External datatype flavour is used to carry this information as follows:</font>
                            </p>
                            <p class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                <font face="Times New Roman" size="3">If it is an NHS Number:</font>
                            </p>
                            <ul>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>root</em> attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.1"</font>
                                    </div>
                                </li>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>extension</em> attribute will contain the NHS Number</font>
                                    </div>
                                </li>
                            </ul>
                            <p class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                <font face="Times New Roman" size="3">If it is an Old Format or Temporary NHS Number:</font>
                            </p>
                            <ul>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>root</em> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.3"</font>
                                    </div>
                                </li>
                                <li>
                                    <div class="63C7BF90-553E-11DB-A2A2-929938389B48">
                                    <font face="Times New Roman" size="3">The <em>extension</em> attribute will contain the Old Format or Temporary NHS Number</font>
                                    </div>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="*"
                minimumMultiplicity="0" name="addr" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">Address(es) of the patient.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The particular flavour of the address datatype used here is Address streetAddressLine Typed (format 2 in the datatypes description), plus:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">Optional Postcode</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Optional Address Key</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Optional Description</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Mandatory Use</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Optional Useable period</font>
                                    </li>
                                </ul>
                                <p>
                                    <font face="Times New Roman" size="3">This means that the address will contain the following components:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">Between one and five <em>streetAddressLine</em> elements. Excludes postcode, may be vernacular or PAF-derived. For vernacular addresses, the following formatting convention should normally apply although there may be some exceptions:</font>
                                    </li>
                                    <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">Line 1: premises ID</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Line 2: no. / thoroughfare</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Line 3: locality</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Line 4: post town</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Line 5: county</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">Lines 1 or 2 and line 4 should normally be mandatory although there may be some exceptions</font>
                                    </li>
                                    </ul>
                                    <li>
                                    <font face="Times New Roman" size="3">A <em>postalCode</em> element to carry a postcode (optional)</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">An <em>addressKey</em> element to carry a PAF key (optional)</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">A <em>desc</em> element to carry a free-text description of the nature of the address (e.g. "On holiday") (optional, may only be present for a temporary address, i.e. if the <em>use</em> attribute is "TMP")</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>use</em> attribute to denote the type of address. Only the values "H" (Home address) and "TMP" (Temporary address) are permitted here. (mandatory)</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">A <em>useablePeriod</em> element to contain the dates for which the address is / will be current as a range, supplied in the <em>low</em> and <em>high</em> sub-elements. Only current and future dated addresses are provided here. (optional)</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="addr"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="AD"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="confidentialityCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates whether or not the patient's details are marked as sensitive.</font>
                            </p>
                            <p>
                                <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                            </p>
                            <ul>
                                <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain a value from the list of codes in the <u>InformationSensitivity</u> vocabulary</font>
                                </li>
                                <li>
                                    <font face="Times New Roman" size="3">The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.1"</font>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="confidentialityCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="InformationSensitivity"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Subject">
            <derivationSupplier className="Participation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    nodeOrientation="Down" shapeId="Sheet.15"
