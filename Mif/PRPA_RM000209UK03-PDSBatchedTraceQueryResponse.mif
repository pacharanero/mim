    <ownedEntryPoint className="PdsTraceMatch" id="PRPA_RM000209UK03"
        isAbstract="false" name="BatchTraceResponse">
        <annotations>
            <description>
                <text>
                    <p>Return match after a batch trace search using input parameters.</p>
                    <p>Matching algorithms will deliver a quantitative matching level and</p>
                    <p>PDS policy may vary on the level required for a trusted match.</p>
                </text>
            </description>
            <otherAnnotation type="html"/>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="PRPA_RM000209UK03">
                <position x="4.31804" y="0.02756"/>
                <size height="0.71944" width="3.29791"/>
                <anchorage connectToShapeId="Sheet.1">
                    <position x="5.967" y="0.747"/>
                    <graphEdge>
                        <anchor>
                            <position x="5.967" y="1.226"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
    <ownedClass>
        <class isAbstract="false" name="PdsTraceMatch">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.1" shapeTemplate="Act">
                    <position x="5.339" y="1.226"/>
                    <size height="0.75" width="1.25"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <font face="times new roman,times" size="3">
                                <strong>Parent class linking to  details returned in the query response. As well as confirming that  the NHS number exists on the PDS, a number of data fields  are also retrieved from the PDS.</strong>
                            </font>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an  Observation act.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
