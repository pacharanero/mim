                    <position x="0.019" y="4.717"/>
                    <size height="0.782" width="3.091"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>RegistrationDetails</p>
                        <p>DIM class</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.115">
                            <position x="4.61" y="5.38"/>
                            <size height="0.5" width="1.0"/>
                            <anchorage connectToShapeId="Sheet.71">
