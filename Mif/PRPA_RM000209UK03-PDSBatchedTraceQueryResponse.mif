                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a  subject.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SBJ"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Person">
            <derivationSupplier className="Person" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.21" shapeTemplate="Entity">
                    <position x="8.836" y="0.23944"/>
                    <size height="1.18112" width="2.548"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>BirthOrder for BabyTracing is</p>
                        <p>carried in this entity.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.100">
                            <position x="13.50985" y="0.08"/>
                            <size height="0.5" width="1.4943"/>
                            <anchorage connectToShapeId="Sheet.21">
                                <position x="14.257" y="0.33"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="11.384" y="0.351"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <strong>
                                <font face="times new roman,times" size="3">Parent class linking to and  containing information about a patient which is specific to the person.</font>
                            </strong>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PSN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a Person  entity.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Instance of  a person.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="*"
                minimumMultiplicity="0" name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">Name(s) of the person. </font>
                                </p>
                                <p>
                                    <font face="times new roman,times" size="3">The particular flavour of the person name datatype used here is Person name structured with use (number 6 in the datatypes description). This means that the name will contain the following components: </font>
                                </p>
                                <ul>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>family</em> element to carry  the surname or family name of the person (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">Up to 2 <em>given</em> elements to carry the given names of the person. If the person has more than 2 given names, these will be concatenated in the second given name attribute with a space between each name. The order of the elements is also significant, so the first occurrence of the <em>given</em> element will carry the first given name, and  the second occurrence will carry the second, third, etc. given names (optional)  </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>prefix</em> element to carry  a prefix for the name, such as Mr, Mrs, etc. (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>suffix</em> element to carry  a suffix for the name, such as Jnr, Snr, etc. (optional) </font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A<em> use</em> attribute to denote  the type of name where only Usual, Alias and Preferred name types are supported by Batch Trace (mandatory)</font>
                                    </li>
                                    <li>
                                    <font
                                    face="times new roman,times" size="3">A <em>validTime</em> element to  contain the dates for which the name is / was current as a range, supplied in  the <em>low</em> and <em>high</em> sub-elements. Both the <em>low</em> and  <em>high</em> sub-elements are optional, allowing open-ended ranges to be  specified. (optional)</font>
                                    </li>
                                </ul>
                                <font face="Times New Roman" size="3">
                                    <u>
                                    <strong> Note</strong>
                                    </u> Current and future dated will always be returned and that historic data will also be returned where an advanced trace was performed. If a cross-check trace is invoked and is successful, historic data will not be returned. </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="PN"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="administrativeGenderCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The administrative gender of the  person.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The Coded Only datatype flavour is used  to carry this information as follows:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain  a value from the list of codes in the <u>Sex</u> vocabulary.</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier
                    attributeName="administrativeGenderCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="Sex"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="birthTime" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div style="height: 100%; width: 100%">
                                <div style="height: 100%; width: 100%">
                                    <div>
                                    <p>To provide the date the patient was born.</p>
                                    <p>The date/time may be given in one of the following formats:</p>
                                    <ul>
                                    <li>YYYYMMDDHHMM where the full date and time of birth is known;  </li>
                                    <li>YYYYMMDD where the full date of birth is known;  </li>
                                    <li>YYYYMM or YYYY where the full date of birth is not known.</li>
                                    </ul>
                                    <p>One of the Date and Time, Date Only, Date Month or Date Year datatype  flavours is used to carry this information as follows:</p>
                                    <ul>
                                    <li>The <i>value</i> attribute will contain the date value in the format  indicated.                                                     </li>
                                    </ul>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="birthTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="deceasedTime" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <div style="height: 100%; width: 100%">
                                    <div style="height: 100%; width: 100%">
                                    <div>
                                    <p>To provide the date (and time where available) the patient died, where  relevant.</p>
                                    <p>The date/time may be given in one of the following formats:</p>
                                    <ul>
                                    <li>YYYYMMDDHHMM where the full date and time of death is known;  </li>
                                    <li>YYYYMMDD where the full date of death is known;  </li>
                                    <li>YYYYMM or YYYY where the full date of death is not known.</li>
                                    </ul>
                                    <p>One of the Date and Time, Date Only, Date Month or Date Year datatype  flavours is used to carry this information as follows:</p>
                                    <ul>
                                    <li>The <em>value</em> attribute will contain the date value in one of the formats  indicated.                                                     </li>
                                    </ul>
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="deceasedTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="multipleBirthOrderNumber" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <div>Describes the sequence in the case of multiple births (e.g. twins, triplets etc).<br/>
                                    <br/>For births that are not a part of a multiple birth, this will be set to 1.<br/>
                                    <br/>Note that permissible values are 1-9, with any value between<br/>
                                    <br/>
                                    <ul>
                                    <li>1 and 7 inclusive indicating the actual birth order number,</li>
                                    </ul>
                                    <ul>
                                    <li>8 meaning "Not applicable" and</li>
                                    </ul>
                                    <ul>
                                    <li>9 meaning "Not known".</li>
                                    </ul>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier
                    attributeName="multipleBirthOrderNumber"
                    className="Person" staticModelDerivationId="1"/>
                <type name="INT"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Subject4">
            <derivationSupplier className="Participation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    nodeOrientation="Right" shapeId="Sheet.25"
                    shapeTemplate="Participation" textWrappingWidth="66.0">
                    <position x="3.02" y="2.57961"/>
                    <size height="0.30278" width="1.586"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>A heading for indicating that the patient is the subject of the  associated death notification.</strong>
                            </p>
                            <p>
                                <strong>This shall be present where the patient's death date/time is given in  the person.deceasedTime field. </strong>
                            </p>
                            <p>
                                <strong>This shall not be present where the person.deceasedTime field is not  present.</strong>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="SBJ"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that the patient is the subject of the associated death  notification.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SBJ"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="AssignedEntity">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.31" shapeTemplate="Role">
                    <position x="13.551" y="3.79228"/>
                    <size height="0.51445" width="1.558"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <strong>
                                <font face="times new roman,times" size="3">The organisation acting as  health care provider, i.e. performing the patient care provision.</font>
                            </strong>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="ASSIGNED"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is an Assigned  role.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ASSIGNED"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>

                            <div>                                                                                                              The identifier of the assigned entity acting as health care provider. This will be one of:      <div style="height: 100%; width: 100%">
                                    <div>
                                    <div>
                                    <div>
                                    <ul>
                                    <li>GP Code  - where the PatientCareProvisionType is "1"</li>
                                    <br/>
                                    <li>GP Practice Code - where the PatientCareProvisionType is "1" (Primary Care)</li>
                                    </ul>
                                    </div>
                                    <div>The Identifier External datatype flavour is used to carry this information as follows:</div>
                                    <div>If it is a GP Practice Code:      </div>
                                    <div>
                                    <ul>
                                    <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.3"</li>
                                    </ul>
                                    <ul>
                                    <li>The extension attribute will contain the GP Practice Code<br/>
                                    </li>
                                    </ul>
                                    </div>
                                    </div>
                                    <div>     A national GP code is carried in the following way:      </div>
                                    <div>
                                    <ul>
                                    <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.2"</li>
                                    </ul>
                                    <ul>
                                    <li>The extension attribute will contain the national GP code itself.</li>
                                    </ul>
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
