    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="PatientCareProvision">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.51" shapeTemplate="Act">
                    <position x="8.61" y="3.62144"/>
                    <size height="0.78112" width="2.775"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Only a code of "1" for PatientCareProvisionType</p>
                        <p>is returned by Batch Trace.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.110">
                            <position x="8.79714" y="4.68"/>
                            <size height="0.5" width="2.42573"/>
                            <anchorage connectToShapeId="Sheet.51">
                                <position x="10.01001" y="4.93"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="9.997" y="4.402"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>A heading for defining a relationship between a patient and his/her  primary care provider (registered GP / GP Practice).</strong>
                            </p>
                            <p>
                                <strong>
                                    <u>Note</u>
                                </strong>
                                <strong>Current and future dated will always be returned and that historic data will also be returned where an advanced trace was performed. If a cross-check trace is invoked and is successful, historic data will not be returned.</strong>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PCPR"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is a patient care provision.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PCPR"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is a defined patient care provision event which has  occurred.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="1" fixedValue="1"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Indicates the type of patient care provision. <br/>
                                    <br/>The Coded with Code System datatype flavour is used to carry this information as follows: <br/>
                                    <br/>
                                </p>
                                <ul>
                                    <li>The code attribute will only contain the value of "1" (representing Primary Care) from the list of codes in the PatientCareProvisionType vocabulary. </li>
                                </ul>
                                <ul>
                                    <li>The codeSystem attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.37</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PatientCareProvisionType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>To provide a date interval during which the patient care provision was  effective.</p>
                                <p>The Date Only datatype flavour is used to carry this information as  follows:</p>
                                <ul>
                                    <li>The <em>low</em> sub-element may be present with the date from which the  patient care provision was effective, provided in YYYYMMDD format in the  <em>value</em> attribute;  </li>
                                    <li>The <em>high</em> sub-element may optionally be present with the date to  which the the patient care provision was effective provided in YYYYMMDD format  in the <em>value</em> attribute. </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
