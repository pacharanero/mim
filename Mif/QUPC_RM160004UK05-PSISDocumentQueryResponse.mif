            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>The display name associated with the author.</p>
                                <p>The datatype must be contrained to either PN or ON (both valid constraints or EN). </p>
                                <ul>
                                    <li>Where PlayingAuthor.classCode is constrained to PSN, the datatype of the 'name' element must be PN.</li>
                                </ul>
                                <ul>
                                    <li>Where PlayingAuthor.classCode is constrained to ORG, the datatype of the 'name' element must be ON.</li>
                                </ul>
                                <p>
                                    <br/>
                                </p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="EN"/>
            </attribute>
        </class>
