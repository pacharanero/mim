    <ownedClass>
        <class isAbstract="false" name="DocumentAuthor">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.87" shapeTemplate="Role">
                    <position x="15.001" y="2.59611"/>
                    <size height="0.64778" width="2.276"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <div>
                                <p>
                                    <strong>The author of the original clinical document which the meta-data is describing.</strong>
                                </p>
                                <p>An author must have either a playing entity, scoping entity or both - structure as defined in the original message.</p>
                            </div>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" isMandatory="true"
                isStructural="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="F1050C90-3C03-11DB-925E-954A05F5B443">Indicates this is an Agent entity.<br/>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="AGNT"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="2"
                minimumMultiplicity="0" name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The ID(s) of the author.</p>
                            <p>
                                <b>WHERE THE PLAYING AUTHOR IS A PERSON:</b>
                            </p>
                            <p>If a person, they must be registered on SDS.<br/>
                            </p>The first instance of id shall carry the SDS User ID, the second instance may carry the SDS User Role Profile ID when present. They shall be carried as follows:<br/>
                            <br/>An SDS identifier that uniquely identifies the Person.<br/>
                            <ul>
                                <li>The <i>root</i> attribute shall contain an OID with the value 1.2.826.0.1285.0.2.0.65 </li>
                                <li>the <i>extension</i> attribute shall contain the SDS User ID, known in the External Interface Specification as User's Unique Identifier as used in the original Document. </li>
                            </ul>An SDS identifier that uniquely identifies the role profile of the person<br/>
                            <ul>
                                <li>The <i>root</i> attribute shall contain an OID with the value 1.2.826.0.1285.0.2.0.67</li>
                                <li>the <i>extension</i> attribute shall contain the SDS Role Profile ID, known in the External Interface Specification as Role Profile Code as used in the original Document.<br/>
                                    <br/>
                                </li>
                            </ul>
                            <b>WHERE THE PLAYING AUTHOR IS AN ORGANISATION:</b>
                            <br/>
                            <br/>The organisation must be registered on SDS.                                  <div>Only one instance shall be used. <br/>  An SDS Organisation shall be  identified as follows:<br/>
                                <ul>
                                    <li>The <i>root</i> attribute shall contain an OID with the value  1.2.826.0.1285.0.1.10</li>
                                    <li>the <i>extension</i> attribute shall contain the SDS Organisation Id, known in the External Interface Specification as the NACS Organisation or Site code as used in the original Document.</li>
                                </ul>
                            </div>
                            <div>
                                <b>WHERE THERE IS NO PLAYING AUTHOR, JUST A SCOPING ORGANISATION</b>:</div>
                            <div>This element will not be present.<br/>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="II"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="code" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Any code that describes a person's job role. <br/>
                                    <br/>The Coded Plain  flavour of the Coded Value (CV) data type shall be used to carry this  information as follows:                        </p>
                                <ul>
                                    <li>The <i>code</i> attribute shall contain the person's job role code<br/>
                                    </li>
                                    <li>The <i>codeSystem</i> attribute shall contain the OID for the code system                           </li>
                                    <li>The <i>displayName </i>attribute shall carry the person's job role name</li>
                                </ul>
                                <div>THIS ELEMENT MUST BE PRESENT FOR ALL RESPONSES WHEN PRESENT IN THE ORIGINAL DOCUMENT WHICH THIS METADATA IS DESCRIBING. </div>
                                <div/>
                                <div>When no Code element is present or applicable in the original Document, this attribute will not be present. <br/>
                                </div>
                                <br/>                                 When the Code element is present in the original Document and already contains a null flavor, this attribute will contain the same null flavor.                             </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CE"/>
