            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <strong>Parent class containing details of a source system, when it takes the form of a National System code.</strong>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
