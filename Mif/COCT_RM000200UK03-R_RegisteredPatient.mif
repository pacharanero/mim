                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="name" sortKey="6">
                <annotations>
                    <designComments>
                        <text>&lt;p&gt;Previous&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">The previous name of the person.</font>
                                    <p>
                                    <font face="Times New Roman" size="3">The particular flavour of the person name datatype used here is Person name unstructured with use. This means that the name will contain the following components:</font>
                                    </p>
                                    <ul>
                                    <li>The whole name, contained as a single string within the element</li>
                                    <li>A <em>use</em> attribute to denote the type of name, fixed to "PREVIOUS" (mandatory)</li>
                                    </ul>
                                </font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="PN"/>
            </attribute>
        </class>
    </ownedClass>
