                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The reason for the registration on a primary care system, also known as Type of Registration.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <i>code</i> attribute will contain a value from the list of codes in the <u>RegistrationReason</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <i>codeSystem</i> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.166"</font>
