            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="0"
                name="sequenceNumber" sortKey="8">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>An optional integer to allow relative <i>priority </i>ordering of this relationship among other like-type relationships having the same source Act. </p>
                            <p>Where there are multiple recipients the value "1" is used indicate the main person or organisation that the report is intended for.<br/>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="sequenceNumber"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="INT"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="InFulfillmentOf2">
            <derivationSupplier className="ActRelationship" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    nodeOrientation="Down" shapeId="Sheet.77"
                    shapeTemplate="ActRelationship" textWrappingWidth="60.0">
                    <position x="13.21475" y="14.01221"/>
                    <size height="1.1439" width="3.16298"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <P>
                            <B>Provides the mechanism for the linking of a performed(Fulfiller) act to the request (Placer) act that is being fulfilled.</B>
                        </P>
                        <P>
                            <B>These are different acts and may be different SnomedCT concepts. A single Fulfilling act may fulfill one or more Placer request acts or multiple Fulfilling acts may be performed in fulfillment of a single Placer request act.</B>
                        </P>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="FLFS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is fulfilling a request.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="FLFS"/>
            </attribute>
            <attribute conformance="R" defaultValue="ON"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="contextControlCode" sortKey="7">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>A code that specifies how this Participation contributes to the context of the current Act and whether it may be propagated to descendant Acts whose association allows such propagation.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="contextControlCode"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="CS"/>
