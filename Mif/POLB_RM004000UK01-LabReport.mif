    <ownedClass>
        <class isAbstract="false" name="PrimaryInformationRecipient">
            <derivationSupplier className="Participation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    nodeOrientation="Left" shapeId="Sheet.71"
                    shapeTemplate="Participation" textWrappingWidth="66.0">
                    <position x="2.23153" y="6.94666"/>
                    <size height="0.56944" width="3.48033"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>Refers to the persons or departments who are the primary business recipient of the laboratory report. This is generally at least the Health Care Professional responsible for the patient at the time of the encounter that gave rise to the request.</b>
                        <p>Anyone who is named in the corresponding request as a primary recipient, should receive a copy of the report and be listed here. The author of the request is generally considered the main recipient and should be listed as the first PRCP, using the sequence number attribute, below. Other PRCP recipients beyond the request author can be considered to be 'copies', and permission to read the message is implied.</p>
                        <p>There is a distinction with tracker (TRC) recipients, of which there is no implicit permission to read the report.</p>
                        <p>See also the different interactions that include this message and the receiver responsibilities therein.</p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PRCP"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates the role of primary recipient.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="Participation" staticModelDerivationId="1"/>
