            </attribute>
            <attribute conformance="R" defaultValue="false"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="contextConductionInd" sortKey="8">
                <annotations>
                    <otherAnnotation type="html">
                        <text>If true, associations in the parent act are conducted across the ActRelationship to the child act.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="contextConductionInd"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="InterpretationRange">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.83" shapeTemplate="Act">
                    <position x="18.76581" y="12.01611"/>
                    <size height="0.91445" width="2.73143"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <P>
                            <B>This Act carries the Interpretation Range against which the source act was/may reinterpreted. This is generally a Reference Range but may also be a Reference Change Value (RCV). Both may be carried in the same message for each appropriate observation Event.</B>
                        </P>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an observation.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN.CRT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an event criterion.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN.CRT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="26">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Carries the actual value(s) of the Interpretation range that have been used for interpretation of the Observation Event value in the source act. It should be noted that a value does not have to be present in the Source act in order to provide an interpretation of Susceptibility.</P>
                            <P>EITHER:-</P>
                            <P>The Value shall be a numerical (interval) which may have a Low and High, a Low or a High value.</P>
                            <P>Generally, interpretation ranges are nn.nn - nn.nn but in some instances, there may only be a High value(&lt; nn.nn) or a Low value(&gt; nn.nn)</P>
                            <P>OR:-</P>
                            <P>The Value may be a Reference Change Value (RCV)95% probability or RCV 99% probability value as an absolute, real number with associated unit or a percentage.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="PQ"/>
                </type>
            </attribute>
            <attribute conformance="R" defaultValue="N"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="interpretationCode" sortKey="27">
                <annotations>
                    <designComments>
                        <text>&lt;p&gt;Normal&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>
                            <P>Default to 'N'. Indicates that this is a 'Normal' <B>type</B> value range (not a normal value)</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="interpretationCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CE"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ObservationInterpretation"/>
            </attribute>
        </class>
    </ownedClass>
