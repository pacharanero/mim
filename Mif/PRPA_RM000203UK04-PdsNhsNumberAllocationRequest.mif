                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>A heading for providing details about the patient when associated with other providers, such as pharmacies nominated by the patient.The otherProviderPatient grouping may occur between zero and three times, once for each type of pharmacy details to be registered on the PDS.</b>
                        </p>
                        <p>
                            <b>NB: Only NCRS compliant pharmacies may be selected.</b>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that the role is that of a patient.</p>
                            <ul>
                                <li>Fixed value: "PAT" (Patient)</li>
                            </ul>
                            <p>The classCode is carried as an attribute of the <em>playedOtherProviderPatient</em>element.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
        </class>
