    <ownedEntryPoint className="PdsRegistrationRequest"
        id="PRPA_RM000203UK04" isAbstract="false" name="PdsAllocateNhsNumberRequest">
        <annotations>
            <description>
                <text>
                    <p>To make a request on PDS to allocate a Number.</p>
                    <p>The minimum set of data items judged adequate to make a NHS</p>
                    <p>Number will vary according to PDS operational policy.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text>A heading for providing information about a request to allocate a NHS number for a patient.</text>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="PRPA_RM000203UK04">
                <position x="4.75939" y="0.02778"/>
                <size height="0.71944" width="3.27322"/>
                <anchorage connectToShapeId="Sheet.1">
                    <position x="6.396" y="0.74722"/>
                    <graphEdge>
                        <anchor>
                            <position x="6.396" y="1.34722"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
