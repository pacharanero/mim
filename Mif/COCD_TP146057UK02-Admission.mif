            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="2" minimumMultiplicity="1"
                name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <b> The first (mandatory) id is a unique identifier for this instance of the Admission  procedure</b>
                                </p>
                                <p>The Identifier Global datatype flavour is used to carry the identifier as  follows:</p>
                                <ul>
                                    <li>The <i>root</i> attribute shall contain a DCE UUID.</li>
                                </ul>
                            </div>
                            <div>
                                <b>The second (optional) id is a local identifier for this instance of the Admission procedure</b>
                                <span id="XSLTPageNoTree123:XSLTOut">
                                    <br/>
                                </span>
                                <br/>The IdentifierExternal datatype flavour is used to carry this information as follows:<ul>
                                    <li>The <i>root</i> attribute shall contain the local OID</li>
                                    <li>The <i>extension</i> attribute shall contain the  local identifier</li>
                                </ul>
                                <p>Note the OID is not specificied within the MIM as it is local to the system that recorded the admission.</p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Procedure" staticModelDerivationId="1"/>
                <type name="LIST">
                    <supplierBindingArgumentDatatype name="II"/>
                </type>
            </attribute>
            <attribute conformance="R" defaultValue="305056002"
                fixedValue="305056002" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>A SnomedCT code taken from the vocabulary shown. </p>
                                <p>The Concept Descriptor (CD) with CDA URL datatype/flavour shall be used to  carry this information as follows: </p>
                                <ul>
                                    <li>The <i>code</i> attribute shall contain a code from the relevant  	vocabulary                          </li>
                                    <li>The <i>codeSystem</i> attribute shall contain the OID for SnomedCT  	                         </li>
                                    <li>The <i>displayName</i> attribute shall carry a description associated  	with the code in SnomedCT                          </li>
                                    <li>The <i>originalText</i> element can be used to carry a <i>reference</i>  	element. This can link the coded item to the relevant text in the CDA  	section                          </li>
                                    <li>
                                    <i>qualifier </i>(s) may be used if required                         </li>
                                </ul>
                            </div>
                            <div> Note the implementation guidance for the domain where this template is used  should be consulted regarding correct usage                      of the <i>originalText</i>  element.</div>
                            <div/>
                            <div>
                                <br type="_moz"/>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Procedure" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SnomedCT"/>
            </attribute>
            <attribute conformance="R" defaultValue="completed"
                fixedValue="completed" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="statusCode" sortKey="9">
                <annotations>
                    <otherAnnotation type="html">
                        <text>The status of the Admission Procedure. <br/>
                            <p>The Coded Only datatype flavour is used to carry this information as  follows:<br/>
                            </p>                                            The <i>code</i> attribute will contain a one of the following codes from  the Act Status vocabulary:  <br/>
                            <ul>
                                <li>completed</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="statusCode"
                    className="Procedure" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ActStatus"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="effectiveTime" sortKey="10">
