    <ownedClass>
        <class isAbstract="false" name="PatientCareProvision">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.575" shapeTemplate="Act">
                    <position x="20.8645" y="14.25999"/>
                    <size height="0.91445" width="3.049"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Code indicates the type of patient</p>
                        <p>care provision, for example, primary</p>
                        <p>care or nominated pharmacy.</p>
                        <p>EffectiveTime is only relevant to</p>
                        <p>primary care.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.813">
                            <position x="22.76739" y="17.01"/>
                            <size height="0.85556" width="1.82161"/>
                            <anchorage connectToShapeId="Sheet.575">
                                <position x="23.6782" y="17.43778"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="22.389" y="15.17444"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <strong>Parent class linking to and containing information about a GP, primary care organisation or nominated pharmacy responsible for a patient over a period of time.</strong>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PCPR"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates this is a Patient Care Provision.<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PCPR"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates this is an event.<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div>
                                    <p> A unique identifier for the patient care provision details. </p>
                                    <p>This identifier is allocated by the PDS. The Identifier External datatype flavour is used to carry this information as follows: </p>
                                    <ul>
                                    <li>The <em>root </em>attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.18.1" </li>
                                    </ul>
                                    <ul>
                                    <li>The <em>extension </em>attribute will contain the PDS Allocated Object Identifier </li>
                                    </ul>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Act" staticModelDerivationId="1"/>
                <type name="II"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div>
                                    <p>Indicates the type of patient care provision.</p>
                                    <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                                    <ul>
                                    <li>The <em>code </em>attribute will contain a value from the list of codes in the <u>PatientCareProvisionType </u>vocabulary </li>
                                    </ul>
                                    <ul>
                                    <li>The <em>codeSystem </em>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.37" </li>
                                    </ul>
                                    <p>NB Only one of each type of pharmacy data ("P1","P2" or "P3") can be provided.</p>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PatientCareProvisionType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div>
                                    <p>The effective dates for the care provision relationship represented as a range, supplied in the <em>low </em>and <em>high </em>sub-elements. Both the <em>low </em>and <em>high </em>sub-elements are optional, allowing open-ended ranges to be specified. </p>
                                    <p>May only be present where the PatientCareProvisionType is "1" (Primary care).</p>
                                    <p>The effective from date (the <em>low </em>sub-element) must not be in the future. </p>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
