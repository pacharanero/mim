                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div class="A1D42350-6056-11DB-AA6A-C57217F5635D">
                            <strong>Parent class linking to and containing information about a patient which is specific to the person.</strong>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PSN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>Indicates that this is a Person entity.</div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="B4514EB0-6135-11DB-9240-9A15D4C2FF5C"> Indicates that this is an Instance of a person. </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="multipleBirthOrderNumber" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <div>Describes the sequence in the case of multiple births (e.g. twins, triplets etc).<br/>
                                    <br/>For births that are not a part of a multiple birth, this will be set to 1.<br/>
                                    <br/>Note that permissible values are 1-9, with any value between<br/>
                                    <br/>
                                    <ul>
                                    <li>1 and 7 inclusive indicating the actual birth order number,</li>
                                    </ul>
                                    <ul>
                                    <li>8 meaning "Not applicable" and</li>
                                    </ul>
                                    <ul>
                                    <li>9 meaning "Not known".</li>
                                    </ul>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier
                    attributeName="multipleBirthOrderNumber"
                    className="Person" staticModelDerivationId="1"/>
                <type name="INT"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="LanguageCommunication">
            <derivationSupplier className="LanguageCommunication" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.25" shapeTemplate="OtherClass">
                    <position x="21.719" y="9.68776"/>
                    <size height="0.92223" width="2.791"/>
                </graphElement>
            </graphicRepresentation>
            <graphicRepresentation presentation="HL7Shadow">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.29" shapeTemplate="OtherClass">
                    <position x="29.27578" y="6.28633"/>
                    <size height="0.75" width="1.882"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong> Parent class containing details of a person's language preferences, where the preferred language is not English.<br/>
                                </strong>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="languageCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p> The Coded Only datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li> The <em>code</em> attribute will contain a value from the list of codes in the <u>HumanLanguage</u> vocabulary.</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="languageCode"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="HumanLanguage"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="proficiencyLevelCode" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Indicates whether an interpreter is required for this person.</p>
                                <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li> The <em>code </em>attribute will contain a value from the list of codes in the <u>InterpreterRequired</u> vocabulary</li>
                                </ul>
                                <ul>
                                    <li> The <em>codeSystem </em>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.39"</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="proficiencyLevelCode"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="InterpreterRequiredIndicator"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="preferenceInd" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>This identifies the patient's preferred language, always 1 ("true") in this case. </p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="preferenceInd"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="RelatedPersonRole">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="true"
                    shapeId="Sheet.33" shapeTemplate="Role">
                    <position x="24.66252" y="7.90999"/>
                    <size height="3.5" width="2.54748"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>Details of people related to the patient. These may be proxy, legal guardian, or family/close contact type relationships.</strong>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" isMandatory="true"
                isStructural="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="classCode" sortKey="0">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Indicates the type of related person role.</p>
                                <p>The Coded Only datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li>The <em>classCode </em>attribute will contain a value from the list of codes in the <u>x_RelatedPerson</u> vocabulary.</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="x_RelatedPerson"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="0">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p> A unique identifier for the related person details. This identifier is allocated by the PDS.</p>
                                <p>The Identifier External datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li>The <em>root </em>attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.18.1"</li>
                                </ul>
                                <ul>
                                    <li>The <em>extension </em>attribute will contain the PDS Allocated Object Identifier</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="0">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Indicates further typing of the related person within the overall related person role, i.e. the type of agent (proxy), guardian or personal relationship.</p>
                                <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li>The <em>code </em>attribute will contain a value from the list of codes in the <u>PersonRelationshipType </u>vocabulary</li>
                                </ul>
                                <ul>
                                    <li>The <em>codeSystem </em>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.15"</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PersonRelationshipType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="0">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The time period in which the relationship was valid, represented as a range, supplied in the <em>low </em>and <em>high</em> sub-elements. Both the <em>low </em>and <em>high </em>sub-elements are optional, allowing open-ended ranges to be specified.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Role" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="positionNumber" sortKey="0">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The order in which contact should normally be made with the related person. (Also known as contact ranking.) The value should be in the range 1-99.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="positionNumber"
                    className="Role" staticModelDerivationId="1"/>
                <type name="INT"/>
            </attribute>
        </class>
    </ownedClass>
