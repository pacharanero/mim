                        </p>
                        <p>
                            <b>This link is only present where the historic data indicator was set to 1 (Retrieve all historic information) in the Retrieval Query message to which this is a response, and the source of the request was NHAIS. Where the historic data indicator was set to 0 (No history required) or the source of the request was not NHAIS, this link will not be present.</b>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="SUBJ"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is a subject relationship.<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SUBJ"/>
            </attribute>
        </class>
    </ownedClass>
