    <ownedClass>
        <class isAbstract="false" name="TreatmentEntitlement">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.619" shapeTemplate="Act">
                    <position x="8.58249" y="17.22666"/>
                    <size height="0.91445" width="3.01227"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>Details of the patient's entitlement to Primary Care NHS treatment.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an observation.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an event.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="21" fixedValue="21"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates the type of observation. </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i> attribute will contain the fixed value shown. </li>
                                <li>The <i>codeSystem</i> attribute will contain the OID for the vocabulary.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The business effective date when this information was applicable.<br/>
                            </p>
                            <p>If both a start date and an end date are present the Date or Time Interval Complete data type shall be used: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date. </li>
                                <li>The <i>high</i> attribute shall contain the end date. </li>
                            </ul>
                            <p>If only a start date is present the Date or Time Interval After data type shall be used: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date. </li>
                            </ul>
                            <p>If only an end date is present the Date or Time Interval Before data type shall be used:</p>
                            <ul>
                                <li>The <i>high</i> attribute shall contain the end date. </li>
                            </ul>All dates will use the Date Only flavour in format YYYYMMDD.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates if the patient is entitled to free treatment.</p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i> attribute will contain the fixed value shown. </li>
                                <li>The <i>codeSystem</i> attribute will contain the OID for the vocabulary.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="TreatmentEntitlementType"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="BackOfficeLocationIdentified">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.623" shapeTemplate="Role">
                    <position x="24.89754" y="3.36445"/>
                    <size height="0.64778" width="2.00493"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>Details of the  Back Office location associated with the GP Practice.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="SDLOC"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is a Service Delivery Location role.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SDLOC"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The back office location. This will be one of: </p>
                            <ul>
                                <li>SDS Organisation ID </li>
                                <li>Scottish Area Health Board Code </li>
                            </ul>
                            <p>The Identifier External datatype flavour is used to carry this information as  follows: </p>
                            <p>If it is a SDS Organisation ID:<br/>
                            </p>
                            <ul>
                                <li>The <i>root </i>attribute will contain an OID with the value  "1.2.826.0.1285.0.1.10" </li>
                                <li>The <i>extension </i>attribute will contain the SDS Organisation ID </li>
                            </ul>
                            <p>If it is a Scottish Area Health Board Code: </p>
                            <ul>
                                <li>The <i>root </i>attribute will contain an OID with the value  "2.16.840.1.113883.2.1.3.2.4.16.55" </li>
                                <li>The <i>extension </i>attribute will contain the Scottish Area Health Board Code</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="8">
                <annotations>
                    <otherAnnotation type="html">
                        <text>The time period in which this information is valid as a range, supplied in the  Low and High attributes of the IVL_TS.<br/>
                            <br/>The particular flavour of the  timestamp datatype used here is Date Only (full dates without time). This means  that dates must be in the format YYYYMMDD.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Role" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
