            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <designComments>
                        <text>&lt;p&gt;Date last changed&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>The date the consent value last changed.</p>
                                <p>Shall be present where the type of consent is "4" (Consent to NHS Care Record sharing), and must not be present otherwise.</p>
                                <p>The Date Only datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li>The <em>value </em>attribute will contain the date value in the format YYYYMMDD</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
