    <ownedClass>
        <class isAbstract="false" name="PDSResponse">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.1" shapeTemplate="Act">
                    <position x="15.00778" y="1.65877"/>
                    <size height="0.75" width="1.659"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div class="B1B3FA10-6831-11DB-A9FF-F2D7A3FC57D0">
                            <p>
                                <b>A heading for providing information about the retrieval of requested patient demographic data from PDS.</b>
                            </p>
                            <p>
                                <b> The patient's current nationally recognised identifier will always be present in a successful retrieval. In addition, the PDS will always return the Serial Change Number. Any other data items will only be present if they had been requested in the PDS Retrieval Query this is a response to. </b>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="E9040A20-5EB1-11DB-90AF-E2ABFD555DCD">Indicates that this is an Observation act.<br/>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="719BC1D0-5EBB-11DB-94A5-E2ABFD555DCD">Indicates that this is an Event</div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="PatientRole">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="true"
                    shapeId="Sheet.5" shapeTemplate="Role">
                    <position x="14.22178" y="3.22476"/>
                    <size height="14.3919" width="3.03"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <strong>Parent class linking to and containing information about a patient.</strong>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is a Patient role.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="ED15BF80-602A-11DB-B8EA-85222526D5DD">
                                <div>
                                    <p>The current NHS number of the patient. This will be one of:<br/>
                                    </p>
                                    <ul>
                                    <li>NHS Number</li>
                                    <li>Old Format NHS Number</li>
                                    <li>Temporary NHS Number (issued by an NHAIS registration authority)<br/>
                                    </li>
                                    </ul>
                                    <p>
                                    <br/>The Identifier External datatype flavour is used to carry this information as follows:<br/>
                                    <br/>If it is an NHS Number:<br/>
                                    </p>
                                    <ul>
                                    <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.1"</li>
                                    <li>The extension attribute will contain the NHS Number<br/>
                                    </li>
                                    </ul>
                                    <p>
                                    <br/>If it is an Old Format or Temporary NHS Number:<br/>
                                    </p>
                                    <ul>
                                    <li>The root attribute will contain an OID with the value 2.16.840.1.113883.2.1.3.2.4.3</li>
                                    <li>The extension attribute will contain the Old Format or Temporary NHS Number</li>
                                    </ul>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="confidentialityCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>To indicate the nature of any sensitive information about the patient in coded form.<br/>
                                    <br/> The Coded with Code System datatype flavour is used to carry this information as follows: </p>
                                <ul>
                                    <li>The code attribute will contain a value from the list of codes in the InformationSensitivity vocabulary; </li>
                                </ul>
                                <ul>
                                    <li>The codeSystem attribute will contain the OID referenced in the InformationSensitivity vocabulary. </li>
                                </ul>
                                <p>Only values "S" and "Y" are returned by this Trace, where: </p>
                                <ul>
                                    <li>S - Sensitive <br/>
                                    </li>
                                    <li>Y - Sensitive (P1R1 Legacy Value) </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="confidentialityCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="InformationSensitivity"/>
            </attribute>
        </class>
    </ownedClass>
