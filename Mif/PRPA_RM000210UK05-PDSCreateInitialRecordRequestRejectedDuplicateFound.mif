    <ownedEntryPoint className="PdsRegistrationResponse"
        id="PRPA_RM000210UK05" isAbstract="false" name="PDS Create Initial Record Request Rejected (Duplicate Found)">
        <annotations>
            <description>
                <text>
                    <p>A negative response to the Create Initial Record Request message, where one</p>
                    <p>or more duplicate records were found on the PDS. The message contains details</p>
                    <p>of the duplicate record(s) found.</p>
                </text>
            </description>
            <otherAnnotation type="html"/>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
