                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an actual instance of the entity, and not a general description of a class of entity</p>
                            <ul>
                                <li>Fixed value: "INSTANCE"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>The name of the mother.                                          <p>The PN datatype will be of the flavour <i>Person Name structured, </i>and will and contain:</p>
                            <ul>
                                <li>Exactly one &lt;family&gt;  element, to carry the family name of the mother </li>
                                <li>
                                    <family>One or two &lt;given&gt; elements, to carry the mandatory forename, and optional other forename of the mother</family>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="PN"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="birthTime" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>This contains the Mother's date of birth as a single point in time - date only, without time. </p>
                            <ul>
                                <li>Note, atleast one of the Mother's NHS Number or the Mother's Date of Birth will be returned. </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="birthTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
        </class>
    </ownedClass>
