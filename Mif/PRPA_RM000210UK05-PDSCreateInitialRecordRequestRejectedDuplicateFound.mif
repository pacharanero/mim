        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Mother">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.67" shapeTemplate="Role">
                    <position x="0.385" y="7.0725"/>
                    <size height="0.51445" width="1.25"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>The role of the Mother.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code indicating that the role is that of a Patient</p>
                            <ul>
                                <li>Fixed value: "PAT"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The current nationally recognised identifier for the Mother.<br/>
                            </p>
                            <p>This identifier can be any of the following:      </p>
                            <ul>
                                <li>The new style of NHS number;</li>
                                <li>A temporary NHS number issued by an NHAIS registration authority;</li>
                                <li>An old style NHS number<br type="_moz"/>
                                </li>
                            </ul>
                            <p>The Identifier External dataType flavour is used to carry this information as follows:-  </p>
                            <p>A NHS number is carried in the following way:      </p>
                            <ul>
                                <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.1";     </li>
                                <li>The extension attribute will contain the NHS number itself.</li>
                            </ul>
                            <p>If it is an Old Format or Temporary NHS Number:<br/>
                            </p>
                            <ul>
                                <li>The root attribute will contain an OID with the value  2.16.840.1.113883.2.1.3.2.4.3  </li>
                                <li>The extension attribute will contain the Old Format or Temporary NHS Number</li>
                            </ul>Note, at least one of the Mother's NHS Number or the Mother's Date of Birth will be returned.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
