                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this Entity represents a distinct single instance.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="birthTime" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div style="height: 100%; width: 100%">
                                    <div style="height: 100%; width: 100%">
                                    <div>
                                    <p>To provide the date the patient was born.</p>
                                    <p>The date/time may be given in one of the following formats:</p>
                                    <ul>
                                    <li>YYYYMMDDHHMM (Date and Time)  </li>
                                    <li>YYYYMMDD (Date Only)  </li>
                                    </ul>
                                    <p>One of the Date and Time or Date Only datatype  flavours is used to carry this information as follows:</p>
                                    <ul>
                                    <li>The <i>value</i> attribute will contain the date value in the format  indicated.</li>
                                    </ul>
                                    </div>
                                    <div>The format must be as follows, depending on which message this CMET appears in:</div>
                                    <div>
                                    <ul>
                                    <li>In an allocate message (Allocate or Primary Care Allocate), only Date Only is permitted</li>
                                    <li>In an update (General or Primary Care) or Demographics Notification message, both Date Only and Date and Time are permitted</li>

                                    <li>In all other messages, only Date and Time is permitted.<br type="_moz"/>
                                    </li>
                                    </ul>
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="birthTime"
                    className="Person" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
        </class>
    </ownedClass>
