            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>
                                <font face="times new roman,times" size="3">Parent class containing and linking to information about an entity which is a part of another entity. In this case, it is the birth time part of a person entity.</font>
                            </b>
                        </p>
                        <b>
                            <font face="times new roman,times" size="3"/>
                        </b>
                        <font face="times new roman,times" size="3">
                            <font face="times new roman,times" size="3">
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3"/>
                                    </font>
                                </font>
                            </font>
                        </font>
                        <div>
                            <font face="times new roman,times" size="3">
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <b>
                                    <i> If used in an update-to-PDS message (e.g. General Update Request): </i>
                                    </b>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                </font>
                            </font>
                        </div>
                        <font face="times new roman,times" size="3">
                            <font face="times new roman,times" size="3">
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3"/>
                                    </font>
                                    </font>
                                </font>
                            </font>
                        </font>
                        <div>
                            <font face="times new roman,times" size="3">
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3"/>
                                    </font>
                                    </font>
                                    </font>
