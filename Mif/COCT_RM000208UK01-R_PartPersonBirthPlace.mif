    <ownedEntryPoint className="BirthPlace" id="COCT_RM000208UK01"
        isAbstract="false" name="R_PartPersonBirthPlace">
        <annotations>
            <description>
                <text>
                    <p>CMET to allow notification</p>
                    <p>times with birthplace information.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text/>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="COCT_RM000208UK01">
                <position x="4.67754" y="0.02778"/>
