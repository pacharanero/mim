    <ownedClass>
        <class isAbstract="false" name="RegisteringAuthority">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.131" shapeTemplate="Role">
                    <position x="5.34709" y="1.56611"/>
                    <size height="0.64778" width="2.585"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>A heading for providing details of the authority for the PDS registration.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="ASSIGNED"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this an assigned role.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ASSIGNED"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The identifier of the assigned organisation acting as registration authority. This will be one of:</p>
                            <ul>
                                <li>NHAIS Cypher</li>
                                <li>SDS Organisation ID<br/>
                                </li>
                            </ul>
                            <p>The Identifier External datatype flavour is used to carry this information as follows:</p>
                            <p>If it is an NHAIS Cypher:</p>
                            <ul>
                                <li>The <i>root </i>attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.6"</li>
                                <li>The <i>extension</i> attribute will contain the NHAIS cypher</li>
                            </ul>
                            <p>If it is an SDS Organisation ID:</p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID with the value "1.2.826.0.1285.0.1.10"</li>
                                <li>The <i>extension</i>attribute will contain the national organisation code</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div
                                id="PRPA_HD100100UK13#RoleHeir;RegisteringAuthority/$code" style="width: 100%; height: 100%; background-color: white">
                                <p>To indicate the type of registering authority in coded form.</p>
                                <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li>The <em>code</em>attribute will contain a value from the list of codes in the <u>RegisteringAuthorityType</u>vocabulary;</li>
                                    <li>The <em>codeSystem</em>attribute will contain the OID referenced in the <u>RegisteringAuthorityType</u>vocabulary.</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="RegisteringAuthorityType"/>
            </attribute>
        </class>
    </ownedClass>
