                    <position x="7.93209" y="1.57513"/>
                    <size height="0.30278" width="1.684"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>A heading for providing a link to the party authoring the PDS registration request.</b>
                    </text>
                </otherAnnotation>
