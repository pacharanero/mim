                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <b>A heading for defining a relationship between a patient and his/her primary care provider or for a specific healthcare facility.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PCPR"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div
                                id="PRPA_HD100100UK13#ActHeir;PatientCareProvision/$classCode" style="width: 100%; height: 100%; background-color: white">
                                <p>Indicates that this is a patient care provision.</p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PCPR"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an event.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div
                                id="PRPA_HD100100UK13#ActHeir;PatientCareProvision/$code" style="width: 100%; height: 100%; background-color: white">
                                <p>To provide the type of defined patient care provision, such as primary care provider (registered GP Practice) or a type of pharmacy, in coded form.</p>
                                <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                                <ul>
                                    <li>The <em>code</em>attribute will contain a value from the list of codes in the <u>PatientCareProvisionType</u>vocabulary;</li>
                                    <li>The <em>codeSystem</em>attribute will contain the OID referenced in the <u>PatientCareProvisionType</u>vocabulary.</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PatientCareProvisionType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>To provide a date interval during which the patient care provision was effective.</p>
                            <p>This shall not be present where the patient care provision type is not "Primary care", and shall be present where the patient care provision type is "Primary care".<br/>
                            </p>
                            <p>The Date Only datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>low</i> sub-element may be present with the date from which the patient care provision was effective, provided in YYYYMMDD format in the <i>value</i>attribute. <b>NB: This date shall not be in the future</b>;</li>
                                <li>The <i>high</i> sub-element may optionally be present with the date to which the the patient care provision was effective provided in YYYYMMDD format in the <i>value</i>attribute. <b>NB: This date shall not be in the future.</b>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
