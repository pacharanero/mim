    <ownedClass>
        <class isAbstract="false" name="Person">
            <derivationSupplier className="Person" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.21" shapeTemplate="Entity">
                    <position x="13.31" y="6.17121"/>
                    <size height="0.75" width="2.69"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>A heading for providing information about the person who is the identified patient.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PSN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is a Person entity.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this Entity represents a distinct single instance.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="*" minimumMultiplicity="1"
                name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times" size="3">
                                    <font size="-0">Name(s) of the person.</font>
                                </font>
                                <font face="times new roman,times" size="3">
                                    <p>
                                    <font size="-0">The particular flavour of the person name datatype used here is Person name structured with use (number 6 in the datatypes description). This means that the name will contain the following components:</font>
                                    </p>
                                    <div>
                                    <ul>
                                    <li>
                                    <font size="-0">A <i>family</i> element to carry the surname or family name of the person (mandatory)</font>
                                    </li>
                                    <li>Up to 2 <i>given </i>elements to carry the given names of the person. If the person has more than 2 given names, these will be concatenated in the second given name attribute with a space between each name. The order of the elements is also significant, so the first occurrence of the <i>given</i> element will carry the first given name, and the second occurrence will carry the second, third, etc. given names (optional)</li>
                                    <li>A <i>prefix </i>element to carry a prefix for the name, such as Mr, Mrs, etc. (optional)</li>
                                    <li>A <i>suffix</i> element to carry a suffix for the name, such as Jnr, Snr, etc. (optional)</li>
                                    <li>A <i>use</i> attribute to denote the type of name (mandatory)</li>
                                    <li>A <i>validTime</i> element to contain the dates for which the name is / was current as a range, supplied in the <i>low</i>and <i>high</i> sub-elements. Both the <i>low</i>and <i>high</i> sub-elements are optional, allowing open-ended ranges to be specified. (optional)</li>
                                    </ul>
                                    </div>
                                    <p>One occurrence of current usual name (use type "L") shall be provided; up to one occurrence of a preferred name (use type "PREFERRED") may be provided; and any number of the other types (alias and previous) may also be provided.</p>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="PN"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="LanguageCommunication">
            <derivationSupplier className="LanguageCommunication" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.25" shapeTemplate="OtherClass">
                    <position x="11.65218" y="4.86009"/>
                    <size height="0.92223" width="2.69564"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>A heading for providing information about the language preferred by the person where it is not English.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="languageCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>To provide the language in coded form.</p>
                            <p>The Coded Only datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i>attribute will contain a value from the list of codes in the <u>HumanLanguage</u>vocabulary.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="languageCode"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="HumanLanguage"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="proficiencyLevelCode" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>To provide the interpreter required indicator in coded form.</p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i>attribute will contain a value from the list of codes in the <u>InterpreterRequiredIndicator</u>vocabulary;</li>
                                <li>The <i>codeSystem</i>attribute will contain the OID referenced in the <u>InterpreterRequiredIndicator</u>vocabulary.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="proficiencyLevelCode"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="InterpreterRequiredIndicator"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="preferenceInd" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>An indicator specifying whether or not the language is preferred by the person.</p>
                            <p>As the requirement for PDS is to only provide the language preferred by the person where it is not English, the preferenceInd shall be set to "true".</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="preferenceInd"
                    className="LanguageCommunication" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
    </ownedClass>
