    <ownedClass>
        <class isAbstract="false" name="PatientCareProvision">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.51" shapeTemplate="Act">
                    <position x="6.38278" y="8.98999"/>
                    <size height="0.78112" width="2.735"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>Parent class linking to and containing information about a GP or  primary care organisation responsible for a patient over a period of time. </strong>
                            </p>
                            <p>
                                <strong>Current data is always returned. History is only returned when historicDataIndicator  in Advanced Trace Query is set to "1"</strong>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PCPR"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is a Patient Care Provision act.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PCPR"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="47C5F9C0-61EA-11DB-9B8E-A1BB6C505412">Indicates that this is an Event.<br/>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="1" fixedValue="1"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>Indicates the type of patient care provision.  </p>
                                <p>The Coded with Code System datatype flavour is used to carry this information as follows:      </p>
                                <ul>
                                    <li>The code attribute will contain only contain a  value of "1" from the list of codes in the PatientCareProvisionType vocabulary </li>
                                </ul>
                                <ul>
                                    <li>The codeSystem attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.37"</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PatientCareProvisionType"/>
            </attribute>
