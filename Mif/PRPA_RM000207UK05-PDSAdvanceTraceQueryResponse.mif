            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="719BC1D0-5EBB-11DB-94A5-E2ABFD555DCD">Indicates that this is an  Event.</div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="01" fixedValue="01"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="E552C880-6D84-11DB-A17A-DDD9F0EF35D3">Indicates the type of  registration. In this case, it is the registration of a record onto an NHAIS  system. </div>
                            <div class="E552C880-6D84-11DB-A17A-DDD9F0EF35D3">The Coded with Code System  datatype flavour is used to carry this information as follows: </div>
                            <div class="E552C880-6D84-11DB-A17A-DDD9F0EF35D3">
                                <ul>
                                    <li>The <em>code </em>attribute will contain the value "01" (NHAIS Registration)  from the list of codes in the <u>DemographicRegistrationType</u> vocabulary  </li>
                                </ul>
                            </div>
                            <div class="E552C880-6D84-11DB-A17A-DDD9F0EF35D3">
                                <ul>
                                    <li>The <em>codeSystem </em>attribute will contain the OID  "2.16.840.1.113883.2.1.3.2.4.17.165"</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicRegistrationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div class="5FE56A30-6D85-11DB-A17C-DDD9F0EF35D3">The time period in which the  information is valid, represented as a range, supplied in the <em>low </em>and  <em>high </em>sub-elements. </div>
                            <div class="5FE56A30-6D85-11DB-A17C-DDD9F0EF35D3">
                                <p>Both the <em>low </em>and <em>high </em>sub-elements are optional, allowing  open-ended ranges to be specified.</p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
