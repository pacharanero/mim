                    <text>
                        <b>An alternative identifier which the patient may also be known by.</b>
                        <br/>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an Observation act.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an Event.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="27" fixedValue="27"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div>
                                    <p>A code from the vocabulary shown indicating the type of identifier being described.<br/>
                                    </p>
                                    <p>The  Coded Plain flavour of Coded Value (CV) datatype shall be used to carry this information  as follows:</p>
                                    <ul>
                                    <li>The <i>code</i> attribute shall contain the value.                           </li>
                                    <li>The <i>code System</i> attribute shall contain the OID for the vocabulary  concerned.                         </li>
                                    </ul>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The date  or date range when the alternative identifier is applicable.</p>
                            <p> The Date Only datatype flavour shall be used. <br/>
                            </p>
                            <p>If both a start date and an end date are present: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date.                           </li>
                                <li>The <i>high</i> attribute shall contain the end date.                           </li>
                            </ul>
                            <p>If only a start date is present: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date.                           </li>
                            </ul>
                            <p>If only an end date is present:</p>
                            <ul>
                                <li>The <i>high</i> attribute shall contain the end date.                         </li>
                            </ul>
                            <p/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The alternative identifier.</p>
                            <div>The Identifier External datatype flavour is used to carry this information as follows:</div>
                            <div>
                                <p>If it is a Scottish CHI number:     </p>
                            </div>
                            <div>
                                <ul>
                                    <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.16.53"</li>
                                </ul>
                                <ul>
                                    <li>The extension attribute will contain the Scottish CHI number.<br/>
                                    </li>
                                </ul>
                            </div>
                            <div>     If it is a Blood Donor ID:      </div>
                            <div>
                                <ul>
                                    <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.16.52"</li>
                                </ul>
                                <ul>
                                    <li>The extension attribute will contain the Blood Donor ID.</li>
                                </ul>
                                <div>
                                    <p>If it is a Scottish NHS number:     </p>
                                </div>
                                <ul>
                                    <li>The root attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.16.54"</li>
                                    <li>The extension attribute will contain the Scottish NHS number.</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
