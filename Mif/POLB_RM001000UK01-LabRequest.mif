                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="statusCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="RoleStatus"/>
