            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>The NHS number that identifies the patient. Note that this may be issued as a temporary flavour.</P>
                            <P>NHS numbers are composed of ten numerics. All other formats shall be treated as temporary. This is the only way of differentiating between the two formats in this implementation.</P>
                            <P>The <I>root</I> element identifies the NHS patient numbering scheme represented by OID 2.16.840.1.113883.2.1.4.1 and the <I>extension</I> contains the actual identifier. </P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="II"/>
            </attribute>
            <attribute conformance="R" fixedValue="active"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="statusCode" sortKey="11">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that the role is currently active.<br/>
