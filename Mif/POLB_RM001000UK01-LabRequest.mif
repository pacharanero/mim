    <ownedClass>
        <class isAbstract="false" name="PlacerGroup">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="false"
                    shapeId="Sheet.51" shapeTemplate="Act">
                    <position x="19.21271" y="2.01464"/>
                    <size height="2.11004" width="2.64865"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Allows for sub-orders to be contained</p>
                        <p>within a single master order where</p>
                        <p>there are multiple requested items on</p>
                        <p>each sub-order. All order items SHALL</p>
                        <p>be for the same fulfiller.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.221">
                            <position x="20.97237" y="0.68167"/>
                            <size height="0.85556" width="1.95763"/>
                            <anchorage connectToShapeId="Sheet.51">
                                <position x="21.95119" y="1.10945"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="21.33163" y="2.01465"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <P>
                            <B>The <I>PlacerGroup</I> provides a mechanism for a single <I>LaboratoryRequestGroup</I> to be made up of multiple specimen centric orders. This is not a common occurrence and use of this will not be common. Where this does occur, the specimen will be associated with the <I>PlacerGroup</I> rather than with the <I>LaboratoryRequestGroup</I>
                            </B>
                        </P>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="ACT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an act.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ACT"/>
            </attribute>
            <attribute conformance="R" fixedValue="RQO"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is a request.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="RQO"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="2" minimumMultiplicity="1"
                name="id" sortKey="7">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <br/>A list of identifiers for this placer group.<br/>
                            <br/>The first (mandatory) identifier is a local identifier allocated by the originating system. It is made up of two parts, a root and extension. The Root will be an OID allocated to the system that generates the extension and will be at such a level that the combination of the Root and Extension is universally unique. The extension will be a human readable string generated by the system and may not be unique across the whole system.<br/>
                            <br/>&lt;id root="9.99.999.99.10.2" extension="0001192992"/&gt;<br/>
                            <br/>Where 9.99.999.99. identifies the Hospital organization and 9.99.999.99.10.2 identifies the ID scheme within the Laboratory system that generated the extension.<br/>
                            <br/>The second identifier is for possible future use</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Act" staticModelDerivationId="1"/>
                <type name="LIST">
                    <supplierBindingArgumentDatatype name="II"/>
                </type>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="8">
                <annotations>
                    <designComments>
                        <text>&lt;p&gt;Subset: "SNOMED lab investigation subset_UK_20060401" or DFT&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>

                            <P>Where the PlacerGroup is used as a Grouper for multiple sub-orders, the Act.code shall represent a specific multi sample profile such as DFT, Creatinine clearance taken from <SPAN lang="EN-US">SNOMED lab investigation subset_UK_20060401</SPAN>. It shall never be a specific investigation in its own right.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CD"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SnomedCT"/>
            </attribute>
            <attribute conformance="R" defaultValue="active"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="statusCode" sortKey="13">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Shall be 'Active' unless the message is used in the Nullify interaction where it shall be 'Nullified'</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="statusCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ActStatus"/>
            </attribute>
            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="effectiveTime" sortKey="14">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P> The time when the request is expected to be actioned. This may be a future time, if known or an appropriate nullFlavor (NI). </P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Act" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
            <attribute conformance="R" defaultValue="Routine"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="priorityCode" sortKey="17">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Constrained to "Routine" or "Urgent"</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="priorityCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PriorityType"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Component1">
            <derivationSupplier className="ActRelationship" staticModelDerivationId="1"/>
