            </attribute>
            <attribute conformance="R" defaultValue="AP"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="contextControlCode" sortKey="7">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>A code that specifies how this Participation contributes to the context of the current Act and whether it may be propagated to descendant Acts whose association allows such propagation.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="contextControlCode"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ContextControl"/>
            </attribute>
            <attribute conformance="R" defaultValue="true"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="contextConductionInd" sortKey="8">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>If "true", associations in the parent act are conducted across the ActRelationship to the child act.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="contextConductionInd"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="0"
                name="sequenceNumber" sortKey="9">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Indicates the processing sequence of the order item. Generally not used.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="sequenceNumber"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="INT"/>
            </attribute>
            <attribute conformance="R" defaultValue="false"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="seperatableInd" sortKey="18">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>This attribute indicates whether or not the source Act is intended to be interpreted independently of the target Act.</p>
                            <p>If the source act is intended to be interpreted independently the value shall be "true" otherwise the value shall be "false".</p>
                            <p>The value of seperatableInd shall be evaluated for each usage of the relationship.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="seperatableInd"
                    className="ActRelationship" staticModelDerivationId="1"/>
                <type name="BL"/>
            </attribute>
        </class>
    </ownedClass>
