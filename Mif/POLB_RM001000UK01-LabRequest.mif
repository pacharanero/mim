                            <P>This provides a mechanism for structuring multiple request items under a single Request header. Generally, a request will be composed of one or more request items to be performed on a specimen.</P>
                        </B>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="COMP"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is a component<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="typeCode"
                    className="ActRelationship" staticModelDerivationId="1"/>
