                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <b>Refers to a performer of the Assessment.</b>
                            </p>
                            <p>
                                <b>Where performer participation is used, then all performers must be stated,  even if they authored the act.</b>
                            </p>
                            <p>
                                <b>Where the author did not perform the act then the performer(s) should be  explicitly stated.</b>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="contentId" sortKey="0">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
