            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div contenteditable="false" style="height: 100%; width: 100%">
                                    <div>
                                    <p>This is a unique identifier for this instance of a Assessment.  </p>
                                    <p>The Identifier Global data type flavour is used to carry the  identifiers follows: </p>
                                    <ul>
                                    <li>The <i>root</i> attribute shall contain a DCE UUID.                                                     </li>
                                    </ul>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.uuid.mandatory"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div>
                                    <p>A SnomedCT code from the AssessmentTypeSnCT vocabulary identifying the assessment type. </p>
                                    <p>The Concept Descriptor (CD) with CDA URL datatype/flavour shall be used to  carry this information as follows: </p>
                                    <ul>
                                    <li>The <i>code</i> attribute shall contain a code from the relevant  	vocabulary                                                   </li>
                                    <li>The <i>codeSystem</i> attribute shall contain the OID for SnomedCT  	                                                  </li>
                                    <li>The <i>displayName</i> attribute shall carry a description associated  	with the code in SnomedCT                                                   </li>
                                    <li>The <i>originalText</i> element can be used to carry a <i>reference</i>  	element. This can link the coded item to the relevant text in the CDA  	section                                                   </li>
                                    <li>
                                    <i>qualifier </i>(s) may be used if required                                                  </li>
                                    </ul>
                                </div>
                                <div> Note the implementation guidance for the domain where this template is used  should be consulted regarding correct usage                      of the <i>originalText</i>  element.                                      </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CD"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="AssessmentTypeSnCT"/>
            </attribute>
            <attribute conformance="R" defaultValue="completed"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="statusCode" sortKey="9">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div contenteditable="false" style="height: 100%; width: 100%">
                                    <div>
                                    <p>The status of the Assessment. </p>
                                    <p>The Coded Only data type flavour is used to carry this information as  follows: </p>
                                    <ul>
                                    <li>The <em>code</em> attribute will contain a one of the following codes  from the Act Status vocabulary:  <br/>
                                    <ul>
                                    <li>nullified  </li>
                                    <li>active  </li>
                                    <li>completed. </li>
                                    </ul>
                                    </li>
                                    </ul>
                                    </div>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="statusCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ActStatus"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The time that the Assessment  took place. <br/>
                            </p>
                            <p>The date range shall be carried as follows: </p>
                            <p>If a single point in time is to be carried the Date or Time Point data type  shall be used: </p>
                            <ul>
                                <li>The <i>center </i>attribute shall contain the date.                                                     </li>
                            </ul>This datatype is used if date of the Assessment is not fully known /  available<br/>
                            <p>If both a start date and an end date are present the Date or Time Interval  Complete data type shall be used: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date.                                                       </li>
                                <li>The <i>high</i> attribute shall contain the end date.                                                      </li>
                            </ul>
                            <p>If only a start date is present the Date or Time Interval After data type  shall be used: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date.                                                     </li>
                            </ul>                                 This datatype would only be used if the Assessment is still ongoing. </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>                                     The value associated with the Snomed concept carried in Assessment.code .  </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="ANY"/>
            </attribute>
        </class>
    </ownedClass>
