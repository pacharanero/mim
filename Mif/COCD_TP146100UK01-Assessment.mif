                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div>
                                    <p>The unique identifier for  this instance of the last assessment review.<br/>
                                    </p>
                                    <p>The Identifier Global datatype flavour is used to carry the first  identifier as follows:</p>
                                    <ul>
                                    <li>The <i>root</i> attribute shall contain a DCE UUID                         </li>
                                    </ul>
                                </div>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Observation" staticModelDerivationId="1"/>
