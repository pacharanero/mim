            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The identifier of the assigned organisation acting as the partner child health authority.</p>
                            <p>The Identifier External datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <em>root</em> attribute will contain an OID with the value "<a>1.2.826.0.1285.0.1.10</a>"</li>
                                <li>The <em>extension</em> attribute will contain the NHS SDS Organisation Id</li>
