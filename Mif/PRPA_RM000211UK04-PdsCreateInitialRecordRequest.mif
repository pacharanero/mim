                        <anchor>
                            <position x="15.38389" y="7.85927"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
    <ownedClass>
        <class isAbstract="false" name="Patient">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="false"
                    shapeId="Sheet.1" shapeTemplate="Role">
                    <position x="15.86089" y="4.42927"/>
                    <size height="1.858" width="1.344"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>The role of the Patient who a record is being created for.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code indicating that the role is that of a Patient</p>
                            <ul>
                                <li>Fixed value: "PAT"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="2" minimumMultiplicity="1"
                name="addr" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Address(es) of the patient.</p>
                            <p>The particular flavour of the address datatype used here is Address streetAddressLine Typed (format 2 in the datatypes description), plus:</p>
                            <ul>
                                <li>Optional Postcode</li>
                                <li>Optional Address Key</li>
                                <li>Optional Description</li>
                                <li>Mandatory Use</li>
                            </ul>
                            <p>This means that the address will contain the following components:</p>
                            <ul>
                                <li>Between one and five <i>streetAddressLine</i> elements. Excludes postcode, may be vernacular or PAF-derived. For vernacular addresses, the following formatting convention should be used: <ul>
                                    <li>Line 1: premises ID</li>
                                    <li>Line 2: no. / thoroughfare</li>
                                    <li>Line 3: locality</li>
                                    <li>Line 4: post town</li>
                                    <li>Line 5: county</li>
                                    <li>Lines 1 or 2 and line 4 are mandatory</li>
                                    </ul>
                                </li>
                                <li>A <i>postalCode</i> element to carry a postcode (optional)</li>
                                <li>An <i>addressKey</i> element to carry a PAF key (optional)</li>
                                <li>A <i>desc</i> element to carry a free-text description of the nature of the address (e.g. "On holiday") (optional, may only be present for a temporary address, i.e. if the <i>use</i> attribute is "TMP")</li>
                                <li>The <i>use</i> attribute to denote the type of address. Only the values "H" (Home address) and "TMP" (Temporary address) are permitted here. (mandatory)</li>
                            </ul>
                            <p>One instance of home address (use type "H") is mandatory and one instance of a discharge address (i.e. temporary - use type "TMP") is optional, where different from usual address.</p>
                            <p>
                                <b>NB</b>  The useablePeriod element of the AD dataType should be used to convey the Business Effective Dates, which are full dates without time.   These are dates for which this data is/was current as a range, supplied in the Low and High attributes of the IVL_TS. <br/>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="addr"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="AD"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="*"
                minimumMultiplicity="0" name="telecom" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Specifies a means of communicating remotely with the Person</p>
                            <p>The valid flavours of the TEL datatype are</p>
                            <p>2. Telecommunication address plus use <i>(f)</i>
                            </p>
                            <p>4. Telecommunication address plus use and valid time. <i>(f)</i>
                            </p>
                            <p>
                                <b>NB</b> The useablePeriod element of the TEL dataType should be used to convey the Business Effective Dates, which are full dates without time. These are dates for which this data is/was current as a range, supplied in the Low and High attributes of the IVL_TS.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="telecom"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="SET">
                    <supplierBindingArgumentDatatype name="TEL" typeSpecialisation="TEL.NPFIT.use.required"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Person">
            <derivationSupplier className="Person" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.11" shapeTemplate="Entity">
                    <position x="12.21189" y="3.88954"/>
                    <size height="0.91445" width="2.776"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>The Person entity playing the role of Patient in this message.</b>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PSN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code indicating that the entity is a Person</p>
                            <ul>
                                <li>Fixed value: "PSN"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PSN"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an actual instance of the entity, and not a general description of a class of entity</p>
                            <ul>
                                <li>Fixed value: "INSTANCE"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="name" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p> The name of the person.  </p>
                            <p>The particular flavour of the person name datatype used here is Person name structured with use (number 6 in the datatypes description). </p>
                            <p>This means that the name will contain the following components:      </p>
                            <ul>
                                <li>A <i>family </i>element to carry the surname or family name of the person (optional)     </li>
                            </ul>
                            <ul>
                                <li>Up to 2 given elements to carry the <i>given </i>names of the person. If the person has more than 2 given names, these will be concatenated in the second <i>given </i>name attribute with a space between each name. The order of the elements is also significant, so the first occurrence of the given element will carry the first given name, and the second occurrence will carry the second, third, etc. given names (optional) </li>
                            </ul>
                            <ul>
                                <li>A <i>prefix </i>element to carry a prefix for the name, such as Mr, Mrs, etc. (optional)     </li>
                            </ul>
                            <ul>
                                <li>A <i>suffix </i>element to carry a suffix for the name, such as Jnr, Snr, etc. (optional)     </li>
                            </ul>
                            <ul>
                                <li>A use attribute to denote the type of name.  Only usual name type ("L") is relevant to this interaction (mandatory)   </li>
                            </ul>
                            <ul>
                                <li>A <i>validTime </i>element to contain the Business Effective Dates for which the name is / was current as a range, supplied in the low and high sub-elements.(optional) </li>
                                <ul>
                                    <li>Both the <i>low </i>and <i>high </i>sub-elements are optional, allowing open-ended ranges to be specified. <br/>
                                    </li>
                                    <li>The Business Effective Dates are full dates without time, so the particular flavour of the timestamp dataType used here is Date Only. This means that the dates must be in the format YYYYMMDD. </li>
                                </ul>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="name"
                    className="Person" staticModelDerivationId="1"/>
                <type name="PN"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="multipleBirthOrderNumber" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>For a birth registration this is mandatory and describes the sequence in the case of multiple births (e.g. twins, triplets etc).</p>
                            <p>For births that are not a part of a multiple birth, this will be set to 1.</p>
                            <p>Note that permissible values are 1-9, with any value between</p>
                            <ul>
                                <li>1 and 7 inclusive indicating the actual birth order number,</li>
                                <li>8 meaning "Not applicable" and</li>
                                <li>9 meaning "Not known".</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier
                    attributeName="multipleBirthOrderNumber"
                    className="Person" staticModelDerivationId="1"/>
                <type name="INT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="ethnicGroupCode" sortKey="8">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The ethnic category of the patient represented in coded form.  </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:      </p>
                            <ul>
                                <li>The <i>code </i>attribute shall contain a value from the list of codes in the <u>EthnicCategoryvocabulary</u>.     </li>
                            </ul>
                            <ul>
                                <li>The <i>codeSystem </i>attribute will contain the OID referenced in the <u>EthnicCategoryvocabulary</u>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="ethnicGroupCode"
                    className="Person" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EthnicCategory"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="DeathNotification">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
