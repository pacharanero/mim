                </graphicRepresentation>
                <annotations>
                    <otherAnnotation type="html">
                        <text>This role shall be used when the DeliveryLocationType code attribute is in the set [0,2,3,4,7].<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
            </specializationChild>
            <specializationChild childClassName="DeliveryLocation">
                <graphicRepresentation>
                    <graphElement containerDiagramName="Main" shapeId="Sheet.251">
