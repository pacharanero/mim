    <ownedEntryPoint className="PdsRegistrationEvent"
        id="PRPA_RM000211UK04" isAbstract="false" name="PdsCreateInitialRecordRequest">
        <annotations>
            <description>
                <text>
                    <p>Carries demographic and clinical details of a birth,</p>
                    <p>In order to register a new record on the PDS.</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text/>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Right" shapeId="PRPA_RM000211UK04">
                <position x="11.95077" y="7.56621"/>
                <size height="0.58611" width="2.56912"/>
                <anchorage connectToShapeId="Sheet.19">
                    <position x="14.51989" y="7.85927"/>
