                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The identifier of the organisation acting as service delivery location.</p>
                            <p>The Identifier External datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <em>root</em> attribute will contain an OID with the value "1.2.826.0.1285.0.1.10"</li>
                                <li>The <em>extension</em> attribute will contain the SDS Organisation ID</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A value from the <u>DeliveryLocationType</u> vocabulary indicating the type of location.</p>
                            <ul>
                                <li>Restricted to values [0,2,3,4,7]</li>
                            </ul>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code </i>attribute will contain the appropriate value from the <u>DeliveryLocationType</u> vocabulary</li>
                            </ul>
                            <ul>
                                <li>The <i>codeSystem </i>attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.173"</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DeliveryLocationType"/>
            </attribute>
        </class>
    </ownedClass>
