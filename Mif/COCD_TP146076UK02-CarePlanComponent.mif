                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates this is an event<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="CAFIS"
                fixedValue="CAFIS" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code from the vocabulary shown indicating that this is a CAF information Set. </p>The Coded Value (CV) with CDA URL datatype/flavour shall be used to  carry this information as follows:                                                        <ul>
                                <li>The <i>code</i> attribute shall contain a code from the relevant  	vocabulary                                                </li>
                                <li>The <i>codeSystem</i> attribute shall contain the OID for the  	vocabulary  	                                               </li>
                                <li>The <i>displayName</i> attribute shall carry the description  	associated with the code                                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="CDAObservationType"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code from the vocabulary shown indicating which value from the CAF information Set is used. </p>The  Coded Plain flavour of Coded Value (CV) datatype shall be used to carry this information as follows:  <ul>
                                <li>The <i>code</i> attribute shall contain a code from the relevant  	vocabulary                                                </li>
                                <li>The <i>codeSystem</i> attribute shall contain the OID for the  	vocabulary  	                                               </li>
                                <li>The <i>displayName</i> attribute shall carry the description  	associated with the code</li>
                                <li>The <i>originalText</i> element must be used to carry a <i>reference</i> element to link the coded item to the relevant text in the CDA section </li>
                            </ul> Note the implementation guidance for the domain where this template is used should be consulted regarding correct usage of the <i>originalText</i>  element.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="CAFInformationSet"/>
            </attribute>
        </class>
    </ownedClass>
