    <ownedClass>
        <class isAbstract="false" name="Subject10">
            <derivationSupplier className="Participation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    nodeOrientation="Left" shapeId="Sheet.179"
                    shapeTemplate="Participation" textWrappingWidth="66.0">
                    <position x="21.72597" y="6.90272"/>
                    <size height="0.30278" width="2.36401"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>
                                    <font face="times new roman,times" size="3">A link to an Observation that this role is the subject of.</font>
                                </strong>
                            </p>
                            <p>
                                <font face="Times New Roman" size="3">
                                    <strong>This must not be present where an NHS Number is given in the <em>id</em> attribute of the <em>RelatedPatient</em> class.</strong>
