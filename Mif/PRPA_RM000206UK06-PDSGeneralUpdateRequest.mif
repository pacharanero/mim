                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The value of the HealthSpace registration status.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain a value from the list of codes in the <u>HealthspaceRegistration</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.7"</font>
                                    </li>
                                </ul>
                                <p>
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>HealthspaceRegistration </em>in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</li>
                                    </ul>
                                    </font>
                                    </font>
                                </p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="HealthspaceRegistration"/>
            </attribute>
        </class>
    </ownedClass>
