    <ownedClass>
        <class isAbstract="false" name="AlternativeIdentifier">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.247" shapeTemplate="Act">
                    <position x="12.7938" y="3.26478"/>
                    <size height="1.04778" width="3.01227"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>Details about an alternative identifier that may apply to the patient.</b>
                        </p>
                        <p>
                            <b>In addition to the attributes below, in order to control the update semantics, the following will also be present: </b>
                        </p>
                        <ul>
                            <li>
                                <b> An <em>updateMode</em> attribute to indicate whether the item should be "added", "altered" or "removed" (mandatory)</b>
                            </li>
                        </ul>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an observation.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an event.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A unique identifier for this object within the patient record.</p>
                            <p> The Identifier External datatype flavour is used to carry this information as follows:<br/>
                            </p>
                            <ul>
                                <li>The <i>root </i>attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.18.1"; </li>
                                <li>The <i>extension </i>attribute will contain the PDS Allocated Object Identifier </li>
                            </ul>
                            <p>This attribute shall be used in conjunction with the <i>updateMode</i> attribute in the following way: </p>
                            <ul>
                                <li>This attribute shall not be present when the <i>updateMode</i> is set to "added".</li>
                                <li>This attribute shall be present when the <i>updateMode</i> is set to "altered" or "removed".</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute conformance="R" defaultValue="27" fixedValue="27"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>A code to indicate the type of observation. <p> The Coded with Code System datatype flavour is used to carry this information as follows: </p>
                            <ul>

                                <li> The <i>code</i> attribute will contain the value from the vocab stated. <br type="_moz"/>
                                </li>
                                <li> The <i>codeSystem</i> attribute will contain the OID for the vocabulary.<br/>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The business effective date when this information was applicable.<br/>
                            </p>
                            <p>If both a start date and an end date are present the Date or Time Interval Complete data type shall be used: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date. </li>
                                <li>The <i>high</i> attribute shall contain the end date. </li>
                            </ul>
                            <p>If only a start date is present the Date or Time Interval After data type shall be used: </p>
                            <ul>
                                <li>The <i>low</i> attribute shall contain the start date. </li>
                            </ul>
                            <p>If only an end date is present the Date or Time Interval Before data type shall be used:</p>
                            <ul>
                                <li>The <i>high</i> attribute shall contain the end date.</li>
                            </ul>
                            <font face="times new roman,times" size="3">
                                <font face="times new roman,times" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attributein the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed".</font>
                                    </li>
                                    <li>This attribute may be present when the <em>updateMode</em> is set to "added" or "altered".<br/>
                                    </li>
                                    </ul>
                                    </font>
                                    </font>
                                </font>
                            </font>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>The value of the alternative identifier.</p>
                            <p>This data will be carried as follows: </p>
                            <p>If a <b>Scottish CHI number:</b>
                            </p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.16.53"</li>
                                <li>The <i>extension</i> attribute will contain the Scottish CHI Number.<br/>
                                </li>
                            </ul>
                            <p>If a <b>Blood Donor ID</b>: </p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.16.52"</li>
                                <li>The <i>extension</i> attribute will contain the Blood Donor ID.</li>
                            </ul>
                            <p>If a <b>Scottish NHS number:</b>
                            </p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.16.54"</li>
                                <li>The <i>extension</i> attribute will contain the Scottish NHS Number.</li>
                            </ul>
                            <p> This attribute shall be used in conjunction with the <i>updateMode</i> attribute in the following way: </p>
                            <ul>
                                <li>This attribute shall not be present when the <i>updateMode</i> is set to "removed".</li>
                                <li>This attribute shall be present when the <i>updateMode</i> is set to "added" or "altered".</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
    </ownedClass>
