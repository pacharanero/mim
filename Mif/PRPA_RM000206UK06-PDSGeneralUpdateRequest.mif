    <ownedClass>
        <class isAbstract="false" name="PatientCareProvision">
            <derivationSupplier className="Act" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
                    shapeId="Sheet.105" shapeTemplate="Act">
                    <position x="12.29777" y="9.9981"/>
                    <size height="0.78112" width="2.7468"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Code indicates the type of patient care provision,</p>
                        <p>is a (NCRS-compliant) Nominated Pharmacy</p>
                        <p>responsible for a Patient over a period of time.</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.391">
                            <position x="12.5467" y="11.04588"/>
                            <size height="0.58889" width="2.45822"/>
                            <anchorage connectToShapeId="Sheet.105">
                                <position x="13.77581" y="11.34032"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="13.12171" y="10.77861"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>Parent class linking to and containing information about a pharmacy responsible for a Patient over a period of time.</b>
                        </p>
                        <div>
                            <b>Additionally, in order to control the update semantics, the following will also be present: <ul>
                                    <li>An <i>updateMode</i> attribute to indicate whether the item should be "added", "altered", or "removed" (mandatory)</li>
                                </ul>
                            </b>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PCPR"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <font face="times new roman,times" size="3">Indicates that this is a Patient Care Provision act.</font>
                            </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PCPR"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an event.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Act" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="id" sortKey="3">
                <annotations>
                    <otherAnnotation type="html">
                        <text>A unique identifier for the patient care provision details. This identifier is allocated by the PDS. <p>The Identifier External datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID with the value "2.16.840.1.113883.2.1.3.2.4.18.1"</li>
                                <li>The <i>extension</i> attribute will contain the PDS Allocated Object Identifier</li>
                            </ul>
                            <p>
                                <this>This attribute shall be used in conjunction with the </this>
                                <i>updateMode</i>
                                <this> attribute of PatientCareProvision in the following way:</this>
                            </p>
                            <ul>
                                <li>This attribute must be present when the <i>updateMode</i> is set to "removed" or "altered"</li>
                                <li>This attribute shall not be present when the <i>updateMode</i> is set to "added"<br/>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Act" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">Indicates the type of patient care provision.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <i>code</i> attribute will contain a value from the list of codes in the <u>PatientCareProvisionType</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <i>codeSystem</i> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.37"</font>
                                    </li>
                                </ul>
                                <p>
                                    <font face="Times New Roman" size="3">NB Only one of each type of pharmacy data can be provided, and only values </font>
                                    <font face="Times New Roman" size="3">"P1","P2" and "P3" are allowed.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">This attribute shall be used in conjunction with the <i>updateMode</i> attribute of <i>PatientCareProvision </i>in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <i>updateMode</i> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <i>updateMode</i> is set to "added" or "altered"</li>
                                    </ul>
                                    </font>
                                </p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PatientCareProvisionType"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="PreferredWrittenCommunicationFormat">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
