                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.109" shapeTemplate="Act">
                    <position x="4.18657" y="5.25533"/>
                    <size height="0.78112" width="3.239"/>
                </graphElement>
            </graphicRepresentation>
            <graphicRepresentation presentation="HL7Shadow">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.113" shapeTemplate="Act">
                    <position x="24.02497" y="5.66111"/>
                    <size height="0.75" width="2.7"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <b>
                                    <font face="times new roman,times" size="3">Details of the patient's preferred written communication format.</font>
                                </b>
                            </p>
                            <b>WHEN THIS CLASS IS ASSOCIATED WITH A PATIENT ROLE: In order to control the update semantics, the following will also be present: <ul>
                                    <li>An <i>updateMode</i> attribute to indicate whether the item should be "added", "altered" or "removed" (mandatory).</li>
                                </ul>
                                <p>WHEN THIS CLASS IS NOT ASSOCIATED WITH THE PATIENT:</p>
                            </b>
                            <ul>
                                <li>
                                    <b>
                                    <p>No <i>updateMode </i>will exist in this class, the <i>updateMode </i>attribute from RelatedPersonRole will apply instead.</p>
                                    </b>
                                </li>
                            </ul>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an observation.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an event.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="13" fixedValue="13"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">Indicates the type of observation. In this case, the observation is that of the patient's preferred written communication format.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                </p>
                                <ul>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>code</em> attribute will contain the value "13" (Preferred written communication format) from the list of codes in the <u>DemographicObservationType</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font face="Times New Roman" size="3">The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.17.35"</font>
                                    </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The preferred written communication format.</font>
                                </p>
                                <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows: </font>
                                <font face="Times New Roman" size="3">
                                    <ul>
                                    <li>The <em>code</em> attribute will contain a value from the list of codes in the <u>PreferredWrittenCommunicationFormat</u> vocabulary </li>
                                    <li>The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.17"</li>
                                    </ul>
                                    <p>
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>PreferredWrittenCommunicationFormat </em>in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</li>
                                    </ul>
                                    </font>
                                    </font>
                                    </p>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PreferredWrittenCommunicationFormat"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="SharedSecret">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="false"
