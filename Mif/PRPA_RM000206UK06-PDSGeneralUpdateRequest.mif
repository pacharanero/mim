                <annotations>
                    <designComments>
                        <text>&lt;p&gt;Date last changed&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times"
                                    size="3">The date the consent value last changed. <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <font
                                    face="times new roman,times" size="3">
                                    <p>
                                    <font
                                    face="Times New Roman" size="3">Shall be present where the type of consent is "4" (Consent to NHS Care Record sharing), and must not be present otherwise.</font>
                                    </p>
                                    <p>
                                    <font
                                    face="Times New Roman" size="3">The Date Only datatype flavour is used to carry this information as follows:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">The <em>value</em> attribute will contain the date value in the format YYYYMMDD</font>
                                    </li>
                                    </ul>
                                    <p>
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>Consent </em>in the following way:</font>
                                    <ul>
                                    <li>

                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered" (and the type of consent is Consent to NHS Care Record sharing).</li>
                                    </ul>
                                    </font>
                                    </font>
                                    </p>
                                    </font>
                                    </font>
                                    </font>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="TS"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <font face="times new roman,times"
                                    size="3">The value of the consent status. <font
                                    face="times new roman,times" size="3"/>
                                </font>
                                <font face="times new roman,times" size="3">
                                    <font face="times new roman,times" size="3">
                                    <p>
                                    <font face="Times New Roman" size="3">The Coded with Code System datatype flavour is used to carry this information as follows:</font>
                                    </p>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">The <em>code</em> attribute will contain a value from the list of codes in the <u>Consent</u> vocabulary</font>
                                    </li>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">The <em>codeSystem</em> attribute will contain the OID "2.16.840.1.113883.2.1.3.2.4.16.2"</font>
                                    </li>
                                    </ul>
                                    <p>
                                    <font face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>Consent </em>in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</li>
                                    </ul>
                                    </font>
                                    </font>
                                    </p>
                                    </font>
                                </font>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="Consent"/>
            </attribute>
        </class>
    </ownedClass>
