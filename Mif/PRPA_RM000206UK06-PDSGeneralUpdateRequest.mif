                        <div>
                            <p>
                                <strong>
                                    <font face="times new roman,times" size="3">Details of a next of kin role.</font>
                                </strong>
                            </p>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="NOK"
                isMandatory="true" isStructural="true"
