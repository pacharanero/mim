                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>The identifier of the assigned organisation acting as health care provider. This will be:</p>
                                <ul>
                                    <li>National Pharmacy Code - where the PatientCareProvisionType is "P1","P2" or "P3"</li>
                                </ul>
                                <p>The Identifier External datatype flavour is used to carry this information as follows for the National Pharmacy Code:</p>
                                <ul>
                                    <li>The <i>root</i> attribute will contain an OID with the value "2.16.840.1.113883.2.1.4.3"</li>
                                    <li>The <i>extension</i> attribute will contain the National Pharmacy Code</li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
            </attribute>
        </class>
