                        <text>
                            <p>The identifier of the assigned organisation acting as registration authority. This will be an SDS Organisation ID.<br/>
                            </p>
                            <p>The Identifier External datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>root</i> attribute will contain an OID with the value "1.2.826.0.1285.0.1.10" </li>
                                <li>The <i>extension</i> attribute will contain the SDS Organisation ID.<br/>
                                </li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II" typeSpecialisation="II.NPfIT.oid.mandatory"/>
