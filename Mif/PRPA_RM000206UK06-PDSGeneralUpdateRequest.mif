            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <div>
                            <p>
                                <strong>
                                    <font face="times new roman,times" size="3">Details of the patient's shared secret.</font>
                                </strong>
                            </p>
                            <strong>
                                <font face="Times New Roman" size="3">
                                    <strong>
                                    <font face="Times New Roman" size="3">
                                    <strong>
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman"
                                    size="3">In addition to the attributes below, in order to control the update semantics, the following will also be present: <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">

                                    <font
                                    face="Times New Roman" size="3"/>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                    </strong>
                                    </font>
                                    </strong>
                                </font>
                            </strong>
                            <strong>
                                <font face="Times New Roman" size="3">
                                    <strong>
                                    <font face="Times New Roman" size="3">
                                    <strong>
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">

                                    <font
                                    face="Times New Roman" size="3">
                                    <ul>
                                    <li>

                                    <font
                                    face="Times New Roman" size="3">An <em>updateMode</em> attribute to indicate whether the item should be "added",</font>

                                    <font
                                    face="Times New Roman" size="3">"altered" or "removed".</font>
                                    </li>
                                    </ul>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                    </font>
                                    </strong>
                                    </font>
                                    </strong>
                                </font>
                            </strong>
                        </div>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an observation.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Indicates that this is an event.</text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" defaultValue="15" fixedValue="15"
                isMandatory="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates the type of observation. </p>
                            <p>The Coded with Code System datatype flavour is used to carry this information as follows:</p>
                            <ul>
                                <li>The <i>code</i> attribute will contain the fixed value shown. </li>
                                <li>The <i>codeSystem</i> attribute will contain the OID for the vocabulary.</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DemographicObservationType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="value" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div>
                                <p>
                                    <font face="times new roman,times" size="3">The patient's shared secret, also known as certificate text, is a string of encrypted characters.</font>
                                </p>
                                <p>
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">This attribute shall be used in conjunction with the <em>updateMode</em> attribute of <em>SharedSecret </em>in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This attribute shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    <li>This attribute shall be present when the <em>updateMode</em> is set to "added" or "altered"</li>
                                    </ul>
                                    </font>
                                    </font>
                                    </font>
                                </p>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="value"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="ST"/>
            </attribute>
        </class>
    </ownedClass>
