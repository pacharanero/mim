                                    <font
                                    face="Times New Roman" size="3">
                                    <font
                                    face="Times New Roman" size="3">This link shall be used in conjunction with the <em>updateMode</em> attribute of <em>RelatedPersonRole </em>in the following way:</font>
                                    <ul>
                                    <li>
                                    <font
                                    face="Times New Roman" size="3">This link shall not be present when the <em>updateMode</em> is set to "removed"</font>
                                    </li>
                                    </ul>
                                    </font>
                                    </font>
                                    </font>
                                    </strong>
                                    </p>
                                </font>
                            </strong>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PART"
                isMandatory="true" isStructural="true"
