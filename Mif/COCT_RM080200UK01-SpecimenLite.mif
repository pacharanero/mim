                    <otherAnnotation type="html">
                        <text/>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="contextControlCode"
                    className="Participation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ContextControl"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="Natural">
            <derivationSupplier className="Entity" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.21" shapeTemplate="Entity">
                    <position x="4.8119" y="5.60978"/>
                    <size height="1.18112" width="3.75049"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <P>
                            <B>This is the 'Specimen' Entity itself. This identifies the actual physical specimen.</B>
                        </P>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="ENT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="5">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Indicates that this is an entity.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="ENT"/>
            </attribute>
            <attribute conformance="R" fixedValue="INSTANCE"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="determinerCode" sortKey="6">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Indicates that this is an Instance.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="determinerCode"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="INSTANCE"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="8">
                <annotations>
                    <designComments>
                        <text>&lt;p&gt;Subset: "SNOMED lab specimen subset_UK_20060401" or an organism&lt;/p&gt;</text>
                    </designComments>
                    <otherAnnotation type="html">
                        <text>
                            <p>The type of specimen is identified. It may be EITHER:-</p>
                            <p>A Specimen concept ID taken from the </p>
                            <p class="MsoNormal" style="margin: 0cm 0cm 0pt">
                                <span lang="EN-US">SNOMED lab specimen subset_UK_20060401</span>
                            </p>
                            <p>and optionally post-coordinated with</p>
                            <p class="MsoNormal" style="margin: 0cm 0cm 0pt">
                                <span lang="EN-US">SNOMED lab topography subset_UK_20060401</span>
                            </p>
                            <p class="MsoNormal" style="margin: 0cm 0cm 0pt">
                                <span lang="EN-US">SNOMED lab morphology subset_UK_20060401</span>
                            </p>
                            <span lang="EN-US">
                                <p class="MsoNormal" style="margin: 0cm 0cm 0pt">
                                    <span lang="EN-US">SNOMED lab laterality subset_UK_20060401</span>
                                </p>
                            </span>

                            <p>according to the Principals laid down in "<span style="font-size: 10pt; font-family: Arial">
                                    <font size="2">Principles for carrying Pathology Request and Result data as SnCT concepts</font>" </span>
                                <span style="font-size: 10pt; font-family: Arial">(</span>
                                <span
                                    style="font-size: 8pt; font-family: Arial">NPFIT-<span
                                    style="font-size: 8pt; font-family: Arial">FNT-<span
                                    style="font-size: 8pt; font-family: Arial">TO-<span
                                    style="font-size: 8pt; font-family: Arial">DPM-<span style="font-size: 8pt; font-family: Arial">0378.01)</span>
                                    </span>
                                    </span>
                                    </span>
                                </span>
                            </p>
                            <p>OR:-</p>
                            <p>An identified isolate taken from the SNOMED CT Concept organism%<br/> Exc domestic mammal -%<br/> Exc Kingdom Animalia -%<br/>Exc plant -%<br/> Exc resistant organism -%<br/>Exc trophic life form -%</p>
                            <p>(% = concept and all descendents; Exc = Excluding) </p>
                            <p>Resistant Organisms (ESBL E.coli etc) will be carried as the Species with appropriate observations indicating the susceptibility pattern. </p>
                            <p>Isolates may be identified by Genus or to a Species level only. No post-coordination is allowed. All observations about the organism shall be carried as Observations off the SpecimenObservationCluster to which the Isolate is linked.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="CD"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SnomedCT"/>
            </attribute>
            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="0"
                name="desc" sortKey="11">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>A textual additional description of the specimen to supplement the coded value. This shall only be used where codes are not available to describe the specimen. It shall not be used in place of appropriate codes.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="desc"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="ED"/>
            </attribute>
            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="0"
                name="riskCode" sortKey="15">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Carries any risk associated with the specimen such as Biohazard.</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="riskCode"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="CE"/>
                <supplierDomainSpecification codingStrength="CWE" domainName="EntityRisk"/>
            </attribute>
            <attribute conformance="R" isMandatory="false"
                maximumMultiplicity="1" minimumMultiplicity="0"
                name="handlingCode" sortKey="16">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <P>Identifies any specific handling instructions for the specimen. (Keep refrigerated etc)</P>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="handlingCode"
                    className="Entity" staticModelDerivationId="1"/>
                <type name="CE"/>
                <supplierDomainSpecification codingStrength="CWE" domainName="EntityHandling"/>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="SpecimenStub">
            <derivationSupplier className="Role" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.25" shapeTemplate="Role">
                    <position x="1.76899" y="5.367"/>
                    <size height="0.51445" width="1.54693"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Used to carry the ID of a Parent Sample</p>
                        <p>if there is one (that needs to be identified).</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.109">
                            <position x="1.70048" y="6.24844"/>
                            <size height="0.5" width="2.13091"/>
                            <anchorage connectToShapeId="Sheet.25">
                                <position x="2.76594" y="6.49844"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="2.54245" y="5.88145"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <constraint name="Specimen">
                    <text>
                        <p>classCode is SPEC or ISLT</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.138">
                            <position x="1.0" y="4.67067"/>
                            <size height="0.32778" width="1.51413"/>
                            <anchorage connectToShapeId="Sheet.25">
                                <position x="1.75706" y="4.83456"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="2.38776" y="5.367"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </constraint>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>Identifies the Parent specimen for the current specimen. For an Isolate, this may be used to identify the specimen from which the isolate was cultured. It may not be used to link one isolate to another. For this reason, the classCode is fixed as 'SPEC'.</b>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" isMandatory="true"
                isStructural="true" maximumMultiplicity="1"
                minimumMultiplicity="1" name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>Code to be SPEC or ISLT as appropriate<br/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Role" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="SPEC"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>
                                <br/>The Specimen ID of the Parent specimen.<br/>
                                <br/>It is made up of two parts, a root and extension. The Root will be an OID allocated to the system that generates the extension and will be at such a level that the combination of the Root and Extension is universally unique. The extension will be a human readable string generated by the system and may not be unique across the whole system.<br/>
                                <br/>
                                <id extension="B05.00504875C" root="9.99.999.99.10.2"/>
                                <br/>Where 9.99.999.99. identifies the Hospital organization and 9.99.999.99.10.2 identifies the ID scheme within the Laboratory system that generated the extension B05.00504875C</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id" className="Role" staticModelDerivationId="1"/>
                <type name="II"/>
            </attribute>
        </class>
    </ownedClass>
