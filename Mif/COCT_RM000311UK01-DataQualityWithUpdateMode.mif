    <ownedClass>
        <class isAbstract="false" name="SuspectPatient">
            <derivationSupplier className="Patient" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="true" isWidthAutoSize="true"
                    shapeId="Sheet.7" shapeTemplate="Role">
                    <position x="3.85061" y="1.09944"/>
                    <size height="0.51445" width="1.25"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>This patient class carries NHS numbers which are suspected as confused or duplicated</b>
                        <br/>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="PAT"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an patient role.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="PAT"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="4" minimumMultiplicity="1"
                name="id" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p> A list of NHS numbers associated with the confusion or duplicate.</p>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <div class="ED15BF80-602A-11DB-B8EA-85222526D5DD">
                                    <div>
                                    <p>The current NHS number of the patient. This  will be one of:<br/>
                                    <br/>
                                    </p>
                                    <ul>
                                    <li>NHS Number</li>
                                    <li>Old Format NHS Number</li>
                                    <li>Temporary NHS Number (issued by an NHAIS registration authority)<br/>
                                    </li>
                                    </ul>
                                    <p>
                                    <br/>The Identifier External datatype flavour is used to carry this  information as follows:<br/>
                                    <br/>If it is an NHS Number:<br/>
                                    <br/>
                                    </p>
                                    <ul>
                                    <li>The root attribute will contain an OID with the value  "2.16.840.1.113883.2.1.4.1"</li>
                                    <li>The extension attribute will contain the NHS Number<br/>
                                    </li>
                                    </ul>
                                    <p>
                                    <br/>If it is an Old Format or Temporary NHS Number:<br/>
                                    <br/>
                                    </p>
                                    <ul>
                                    <li>The root attribute will contain an OID with the value  2.16.840.1.113883.2.1.3.2.4.3</li>
                                    <li>The extension attribute will contain the Old Format or Temporary  NHS Number</li>
                                    </ul>
                                    </div>
                                </div>
                            </div>
                            <p/>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="id"
                    className="Patient" staticModelDerivationId="1"/>
                <type name="LIST">
                    <supplierBindingArgumentDatatype name="II"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
    <ownedClass>
        <class isAbstract="false" name="DataQualityType">
            <derivationSupplier className="Observation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    isHeightAutoSize="false" isWidthAutoSize="true"
                    shapeId="Sheet.17" shapeTemplate="Act">
                    <position x="0.01" y="1.13889"/>
                    <size height="2.075" width="2.59061"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <designComments>
                    <text>
                        <p>Note updateMode is only </p>
                        <p>present in schema and therefore </p>
                        <p>not shown on this model</p>
                    </text>
                    <graphicRepresentation>
                        <graphElement containerDiagramName="Main"
                            isHeightAutoSize="true"
                            isWidthAutoSize="true" shapeId="Sheet.38">
                            <position x="2.47236" y="0.17945"/>
                            <size height="0.58889" width="1.65527"/>
                            <anchorage connectToShapeId="Sheet.17">
                                <position x="3.3" y="0.47389"/>
                                <graphEdge>
                                    <anchor>
                                    <position x="2.34155" y="1.13889"/>
                                    </anchor>
                                </graphEdge>
                            </anchorage>
                        </graphElement>
                    </graphicRepresentation>
                </designComments>
                <otherAnnotation type="html">
                    <text>
                        <p>
                            <b>The Type of Data Quality</b>
                        </p>
                        <p>
                            <b>
                                <br/>The use of <i>updatemode</i> is mandated </b>
                            <b>
                                <b>with this class and should  indicate whether the item has been "added", "altered","removed" or unchanged</b>
                            </b>
                            <br/>
                        </p>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="OBS"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="classCode" sortKey="1">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an observation. </p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="classCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="OBS"/>
            </attribute>
            <attribute conformance="R" fixedValue="EVN"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="moodCode" sortKey="2">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>Indicates that this is an event.</p>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="moodCode"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CS"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="EVN"/>
            </attribute>
            <attribute conformance="R" isMandatory="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="code" sortKey="4">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <p>A code to indicate the type of data quality.<br/>
                                <br/> The Coded with Code System datatype flavour is used to carry this information as follows:                         </p>
                            <ul>
                                <li>The code attribute will contain a value from the list of codes in the DataQualityType vocabulary;     </li>
                            </ul>
                            <ul>
                                <li>The codeSystem attribute will contain the OID referenced in the DataQualityType vocabulary</li>
                            </ul>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="code"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="CV"/>
                <supplierDomainSpecification codingStrength="CNE" domainName="DataQualityType"/>
            </attribute>
            <attribute isMandatory="false" maximumMultiplicity="1"
                minimumMultiplicity="0" name="effectiveTime" sortKey="10">
                <annotations>
                    <otherAnnotation type="html">
                        <text>
                            <div contenteditable="false" style="height: 100%; width: 100%">
                                <p>The date  or date range for this data.</p>
                                <p> The Date Only datatype flavour shall be used. This means that all dates will be in the format YYYYMMDD.<br/>
                                </p>
                                <p>If both a start date and an end date are present: </p>
                                <ul>
                                    <li>The <i>low</i> attribute shall contain the start date.                                                 </li>
                                    <li>The <i>high</i> attribute shall contain the end date.                                                 </li>
                                </ul>
                                <p>If only a start date is present: </p>
                                <ul>
                                    <li>The <i>low</i> attribute shall contain the start date.                                                 </li>
                                </ul>
                                <p>If only an end date is present:</p>
                                <ul>
                                    <li>The <i>high</i> attribute shall contain the end date.                      </li>
                                </ul>
                            </div>
                        </text>
                    </otherAnnotation>
                </annotations>
                <derivationSupplier attributeName="effectiveTime"
                    className="Observation" staticModelDerivationId="1"/>
                <type name="IVL">
                    <supplierBindingArgumentDatatype name="TS"/>
                </type>
            </attribute>
        </class>
    </ownedClass>
