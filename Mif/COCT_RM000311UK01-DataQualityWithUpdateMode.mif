    <ownedEntryPoint className="DataQualityType" id="COCT_RM000311UK01"
        isAbstract="false" name="A_DataQualityWithUpdateMode">
        <annotations>
            <description>
                <text>
                    <p>CMET  for holding details</p>
                    <p>of data quality with updateMode attribute</p>
                </text>
            </description>
            <otherAnnotation type="html">
                <text>
                    <p>
                        <b>A CMET to hold information about the patient's Data Quality (DQ) investigation status</b>
                    </p>
                    <p>
                        <b>When this CMET is used the use of <i>updatemode</i> is mandated with the DataQualityType class.</b>
                        <br/>
                    </p>
                    <p>
                        <b>
                            <b/>
                        </b>
                    </p>
                </text>
            </otherAnnotation>
        </annotations>
        <graphicRepresentation>
            <graphElement containerDiagramName="Main"
                isHeightAutoSize="false" isWidthAutoSize="false"
                nodeOrientation="Down" shapeId="COCT_RM000311UK01">
                <position x="0.14622" y="0.02778"/>
                <size height="0.58611" width="2.1668"/>
                <anchorage connectToShapeId="Sheet.17">
                    <position x="1.22962" y="0.61389"/>
                    <graphEdge>
                        <anchor>
                            <position x="1.22962" y="1.13889"/>
                        </anchor>
                    </graphEdge>
                </anchorage>
            </graphElement>
        </graphicRepresentation>
    </ownedEntryPoint>
    <ownedClass>
        <class isAbstract="false" name="Subject12">
            <derivationSupplier className="Participation" staticModelDerivationId="1"/>
            <graphicRepresentation presentation="HL7">
                <graphElement containerDiagramName="Main"
                    nodeOrientation="Right" shapeId="Sheet.1"
                    shapeTemplate="Participation" textWrappingWidth="66.0">
                    <position x="2.60061" y="1.22798"/>
                    <size height="0.30278" width="1.25"/>
                </graphElement>
            </graphicRepresentation>
            <annotations>
                <otherAnnotation type="html">
                    <text>
                        <b>Refers to the suspected patient class which carried the NHS Numbers associated with this data quality</b>
                        <br/>
                    </text>
                </otherAnnotation>
            </annotations>
            <attribute conformance="R" fixedValue="SBJ"
                isMandatory="true" isStructural="true"
                maximumMultiplicity="1" minimumMultiplicity="1"
                name="typeCode" sortKey="1">
