			<attribute conformance="R" isMandatory="true" maximumMultiplicity="1" minimumMultiplicity="1" name="id" sortKey="3">
				<annotations>
					<otherAnnotation type="html">
						<text>
							<div class="3C6C8330-5EA9-11DB-B131-A25AC51C7F82">
								<div>
									<p>This is the unique identifier of the clinical document.</p>
									<p>The Identifier Global datatype flavour is used to carry the identifier as follows:</p>
									<ul>
										<li>The <i>root</i> attribute shall contain a DCE UUID.</li>
									</ul>
								</div>
							</div>
						</text>
					</otherAnnotation>
				</annotations>
				<derivationSupplier attributeName="id" className="Act" staticModelDerivationId="1"/>
