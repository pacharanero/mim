			<attribute conformance="R" defaultValue="OP" fixedValue="OP" isMandatory="true" maximumMultiplicity="1" minimumMultiplicity="1" name="contextControlCode" sortKey="3" isStructural="true">
				<annotations>
					<otherAnnotation type="html">
						<text>
							<p>Specifies how the referrer contributes to the context of the Diagnostic Imaging Report and whether it may be propagated to descendent acts whose association allows such propagation. </p>
							<p>"O" (Overriding)- the association replaces any context of the same or more specific type that has been conducted from the parent act. </p> "P" (Propagating)- the association is conducted to all child acts where the ActRelationship.contextConductionInd is set to "true." </text>
					</otherAnnotation>
				</annotations>
				<derivationSupplier attributeName="contextControlCode" className="Participation" staticModelDerivationId="1"/>
				<type name="CS"/>
				<supplierDomainSpecification codingStrength="CNE" domainName="ContextControl"/>
			</attribute>
