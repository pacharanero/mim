			<attribute conformance="R" isMandatory="true" maximumMultiplicity="1" minimumMultiplicity="1" name="title" sortKey="8">
				<annotations>
					<otherAnnotation type="html">
						<text>
							<div>
								<p>This attribute carries the text associated with the SnomedCT code carried in act.code.<br/>
								</p>
								<p/>
							</div>
						</text>
					</otherAnnotation>
				</annotations>
				<derivationSupplier attributeName="title" className="Act" staticModelDerivationId="1"/>
