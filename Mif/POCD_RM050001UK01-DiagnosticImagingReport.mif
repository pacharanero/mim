			</attribute>
			<attribute conformance="R" isMandatory="true" maximumMultiplicity="1" minimumMultiplicity="1" name="code" sortKey="4">
				<annotations>
					<otherAnnotation type="html">
						<text>
							<div>
								<p>A code from the vocabulary shown indicating that this is a diagnostic imaging report<br/>
								</p>
								<p>The Coded with Code System flavour of Coded Value (CV) datatype shall be used to carry this information as follows:</p>
								<ul>
									<li>The <i>code</i> attribute shall contain the value. </li>
									<li>The <i>codeSystem</i> attribute shall contain the OID for the vocabulary concerned. </li>
								</ul>
								<p/>
							</div>
						</text>
					</otherAnnotation>
				</annotations>
				<derivationSupplier attributeName="code" className="Act" staticModelDerivationId="1"/>
